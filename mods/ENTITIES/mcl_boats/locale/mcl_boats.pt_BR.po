#: mods/ENTITIES/mcl_boats/init.lua:164
msgid "Sneak to dismount"
msgstr "Agache para sair"

#: mods/ENTITIES/mcl_boats/init.lua:630
msgid "Boats are used to travel on the surface of water."
msgstr "Barcos são usados para viajar na superfície da água."

#: mods/ENTITIES/mcl_boats/init.lua:631
msgid ""
"Rightclick on a water source to place the boat. Rightclick the boat to enter "
"it. Use [Left] and [Right] to steer, [Forwards] to speed up and [Backwards] "
"to slow down or move backwards. Use [Sneak] to leave the boat, punch the "
"boat to make it drop as an item."
msgstr ""
"Clique com o botão direito em uma fonte de água para posicionar o barco. "
"Clique com o botão direito no barco para entrar nele. Use [Esquerda] e "
"[Direita] para fazer curva, [Frente] para acelerar e [Trás] para frear e ir "
"para trás. Use [Agachar] para deixar o barco, soque-o para fazê-lo largar "
"como um item."

#: mods/ENTITIES/mcl_boats/init.lua:632
msgid "Boat"
msgstr "Barco"

#: mods/ENTITIES/mcl_boats/init.lua:638
msgid "Water vehicle"
msgstr "Veículo aquático"

#: mods/ENTITIES/mcl_boats/init.lua:647
msgid ""
"Chest Boats are used to travel on the surface of water. And transport goods"
msgstr ""
"Barcos com baú são usados para viajar na superfície da água. E transportar "
"coisas"

#: mods/ENTITIES/mcl_boats/init.lua:648
msgid ""
"Rightclick on a water source to place the boat. Rightclick the boat to enter "
"it. Use [Left] and [Right] to steer, [Forwards] to speed up and [Backwards] "
"to slow down or move backwards. Use [Sneak] to leave the boat, punch the "
"boat to make it drop as an item. Use [Sneak] + [Rightclick] to open the "
"boat's chest"
msgstr ""
"Clique com o botão direito em uma fonte de água para posicionar o barco. "
"Clique com o botão direito no barco para entrar nele. Use [Esquerda] e "
"[Direita] para esterçar, [Frente] para acelerar e [Trás] para desacelerar e "
"mover-se para trás. Use [Agachar] para deixar o barco, soque o barco para "
"fazê-lo largar como um item. Use [Agachar] + [Botão Direito] para abrir o "
"baú do barco"

#: mods/ENTITIES/mcl_boats/init.lua:649
msgid "Chest Boat"
msgstr "Barco com Baú"

