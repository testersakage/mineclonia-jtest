msgid "Enable dust particles in the nether"
msgstr "Povolit prachové částice v pekle"

msgid "Gives ability to control weather"
msgstr "Poskytuje schopnost ovládat počasí"

msgid "Changes the weather to the specified parameter."
msgstr "Změní počasí podle zadaného parametru."

msgid "Error: No weather specified."
msgstr "Chyba: Není zadáno počasí."

msgid "Error: Invalid parameters."
msgstr "Chyba: Neplatné parametry."

msgid "Error: Duration can't be less than 1 second."
msgstr "Chyba: Doba trvání nemůže být kratší než 1 sekunda."

msgid "Error: Invalid weather specified. Use “clear”, “rain”, or “thunder”."
msgstr ""
"Chyba: Zadané počasí je neplatné. Použijte „clear“(jasno), „rain“ (déšť) "
"nebo „thunder“ (bouřka)."

msgid "Toggles between clear weather and weather with downfall (randomly rain, thunderstorm or snow)"
msgstr ""
"Přepíná mezi jasným počasím a počasím srážek "
"(náhodně buď déšť, bouřka nebo sníh)"
