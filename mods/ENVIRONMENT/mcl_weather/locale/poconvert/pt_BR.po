msgid "Enable dust particles in the nether"
msgstr "Habilita partículas de poeira no Nether"

msgid "Gives ability to control weather"
msgstr "Dá a habilidade de controlar o clima"

msgid "Changes the weather to the specified parameter."
msgstr "Muda o clima para o parâmetro especificado."

msgid "Error: No weather specified."
msgstr "Erro: Nenhum clima especificado."

msgid "Error: Invalid parameters."
msgstr "Erro: Parâmetros inválidos."

msgid "Error: Duration can't be less than 1 second."
msgstr "Erro: Duração não pode ser menor que 1 segundo."

msgid "Error: Invalid weather specified. Use “clear”, “rain”, “snow” or “thunder”."
msgstr "Erro: Clima especificado é inválido. Use \"clear\", \"rain\", \"snow\" ou \"thunder\"."

msgid "Toggles between clear weather and weather with downfall (randomly rain, thunderstorm or snow)"
msgstr "Alterna entre clima limpo e clima com quedas (aleatoriamente chuva, tempestade ou neve)"
