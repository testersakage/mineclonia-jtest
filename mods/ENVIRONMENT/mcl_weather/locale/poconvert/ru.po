msgid "Gives ability to control weather"
msgstr "Предоставляет возможность управлять погодой"

msgid "Changes the weather to the specified parameter."
msgstr "Меняет погоду на заданное значение."

msgid "Error: No weather specified."
msgstr "Ошибка: Не указана погода."

msgid "Error: Invalid parameters."
msgstr "Ошибка: Недопустимые параметры."

msgid "Error: Duration can't be less than 1 second."
msgstr "Ошибка: длительность не может быть менее 1 секунды."

msgid "Error: Invalid weather specified. Use “clear”, “rain”, “snow” or “thunder”."
msgstr ""
"Ошибка: Указана неправильная погода. Возможны варианты: «clear» (ясная), "
"«rain» (дождь), «snow» (снег) или «thunder» (гроза)."

msgid "Toggles between clear weather and weather with downfall (randomly rain, thunderstorm or snow)"
msgstr "Переключает между ясной погодой и осадками (случайно выбирается дождь, грозовой шторм или снег)"
