#: mods/HELP/mcl_doc/init.lua:19
msgid "Water can flow into this block and cause it to drop as an item."
msgstr ""
"A água pode fluir para dentro deste bloco e fazer com que ele caia como um "
"item."

#: mods/HELP/mcl_doc/init.lua:28
msgid "This block can be turned into dirt with a hoe."
msgstr "Este bloco pode ser transformado em terra com uma enxada."

#: mods/HELP/mcl_doc/init.lua:30
msgid "This block can be turned into farmland with a hoe."
msgstr "Esse bloco pode ser arado com uma enxada."

#: mods/HELP/mcl_doc/init.lua:38
msgid "This block can be turned into grass path with a shovel."
msgstr "Este bloco pode ser transformado em um caminho de grama com uma pá."

#: mods/HELP/mcl_doc/init.lua:48
msgid "This block acts as a soil for all saplings."
msgstr "Este bloco serve de solo para todas as mudas."

#: mods/HELP/mcl_doc/init.lua:50
msgid "This block acts as a soil for some saplings."
msgstr ""

#: mods/HELP/mcl_doc/init.lua:53
msgid "Sugar canes will grow on this block."
msgstr ""

#: mods/HELP/mcl_doc/init.lua:56
msgid "Nether wart will grow on this block."
msgstr ""

#: mods/HELP/mcl_doc/init.lua:65
msgid ""
"This block quickly decays when there is no wood block of any species within "
"a distance of @1. When decaying, it disappears and may drop one of its "
"regular drops. The block does not decay when the block has been placed by a "
"player."
msgstr ""

#: mods/HELP/mcl_doc/init.lua:67
msgid ""
"This block quickly decays and disappears when there is no wood block of any "
"species within a distance of @1. The block does not decay when the block has "
"been placed by a player."
msgstr ""

#: mods/HELP/mcl_doc/init.lua:77
msgid ""
"This plant can only grow on grass blocks and dirt. To survive, it needs to "
"have an unobstructed view to the sky above or be exposed to a light level of "
"8 or higher."
msgstr ""

#: mods/HELP/mcl_doc/init.lua:79
msgid ""
"This plant can grow on grass blocks, podzol, dirt and coarse dirt. To "
"survive, it needs to have an unobstructed view to the sky above or be "
"exposed to a light level of 8 or higher."
msgstr ""

