#: mods/HUD/mcl_achievements/init.lua:30
msgid "Benchmarking"
msgstr "Banco di prova"

#: mods/HUD/mcl_achievements/init.lua:31
msgid "Craft a crafting table from 4 wooden planks."
msgstr "Assembla un banco da lavoro da 4 assi di legno."

#: mods/HUD/mcl_achievements/init.lua:42
msgid "Time to Mine!"
msgstr "A scavare!"

#: mods/HUD/mcl_achievements/init.lua:43
msgid ""
"Use a crafting table to craft a wooden pickaxe from wooden planks and sticks."
msgstr "Usa assi e bastoni per assemblare un piccone."

#: mods/HUD/mcl_achievements/init.lua:54
msgid "Hot Topic"
msgstr "Tema scottante"

#: mods/HUD/mcl_achievements/init.lua:55
msgid "Use 8 cobblestones to craft a furnace."
msgstr "Assembla una fornace con otto blocchi di pietre."

#: mods/HUD/mcl_achievements/init.lua:66
msgid "Time to Farm!"
msgstr "A zappare!"

#: mods/HUD/mcl_achievements/init.lua:67
msgid ""
"Use a crafting table to craft a wooden hoe from wooden planks and sticks."
msgstr "Usa assi e bastoni per assemblare una zappa."

#: mods/HUD/mcl_achievements/init.lua:78
msgid "Bake Bread"
msgstr "Il pane quotidiano"

#: mods/HUD/mcl_achievements/init.lua:79
msgid "Use wheat to craft a bread."
msgstr "Trasforma il grano in pane."

#: mods/HUD/mcl_achievements/init.lua:91
msgid "The Lie"
msgstr "La Torta Non È una Bugia"

#: mods/HUD/mcl_achievements/init.lua:92
msgid "Craft a cake using wheat, sugar, milk and an egg."
msgstr "Produci una torta utilizzando: grano, zucchero, latte ed uova."

#: mods/HUD/mcl_achievements/init.lua:103
msgid "Getting an Upgrade"
msgstr "Salto di qualità"

#: mods/HUD/mcl_achievements/init.lua:105
msgid "Craft a stone pickaxe using sticks and cobblestone."
msgstr "Assembla un piccone migliore."

#: mods/HUD/mcl_achievements/init.lua:116
msgid "Time to Strike!"
msgstr "Inizia la Lotta!"

#: mods/HUD/mcl_achievements/init.lua:117
msgid ""
"Craft a wooden sword using wooden planks and sticks on a crafting table."
msgstr "Usa delle assi ed un bastone per assemblare una spada."

#: mods/HUD/mcl_achievements/init.lua:129
msgid "Librarian"
msgstr "Bibliotecario"

#: mods/HUD/mcl_achievements/init.lua:130
msgid "Craft a bookshelf."
msgstr "Assembla una libreria per potenziare il tuo tavolo per incantesimi."

#: mods/HUD/mcl_achievements/init.lua:142
msgid "Isn't It Iron Pick"
msgstr "Scintillante Piccone Metallico"

#: mods/HUD/mcl_achievements/init.lua:143
msgid "Craft a iron pickaxe using sticks and iron."
msgstr "Assembla un piccone di ferro utilizzando bastoni e ferro."

#: mods/HUD/mcl_achievements/init.lua:155
msgid "Bullseye"
msgstr ""

#: mods/HUD/mcl_achievements/init.lua:156
msgid "Hit the bullseye of a target block from at least 30 blocks away."
msgstr ""

#: mods/HUD/mcl_achievements/init.lua:165
msgid "DIAMONDS!"
msgstr "DIAMANTI!"

#: mods/HUD/mcl_achievements/init.lua:166
msgid "Pick up a diamond from the floor."
msgstr "Raccogli un diamante dal pavimento."

#: mods/HUD/mcl_achievements/init.lua:171
msgid "Into Fire"
msgstr "Nel Fuoco"

#: mods/HUD/mcl_achievements/init.lua:172
msgid "Pick up a blaze rod from the floor."
msgstr "Raccogli una verga di blaze dal pavimento."

#: mods/HUD/mcl_achievements/init.lua:179
msgid "Cow Tipper"
msgstr "Ribalta la Mucca"

#: mods/HUD/mcl_achievements/init.lua:180
msgid ""
"Pick up leather from the floor.\n"
"Hint: Cows and some other animals have a chance to drop leather, when killed."
msgstr ""
"Raccogli del cuoio dal pavimento.\n"
"Suggerimento: Le mucche ed alcuni altri animali hanno una probabilità di "
"rilasciare del cuoio, quando vengono uccisi."

#: mods/HUD/mcl_achievements/init.lua:186
msgid "Getting Wood"
msgstr "Duro come il legno"

#: mods/HUD/mcl_achievements/init.lua:187
msgid ""
"Pick up a wood item from the ground.\n"
"Hint: Punch a tree trunk until it pops out as an item."
msgstr ""
"Raccogli un elemento di legno dal pavimento.\n"
"Suggerimento: Picchia il tronco di un albero finché non viene lanciato fuori "
"come elemento."

#: mods/HUD/mcl_achievements/init.lua:194
msgid "Who is Cutting Onions?"
msgstr "Chi Ha Tagliato una Cipolla?"

#: mods/HUD/mcl_achievements/init.lua:195
msgid "Pick up a crying obsidian from the floor."
msgstr "Raccogli dell'ossidiana piangente dal pavimento."

#: mods/HUD/mcl_achievements/init.lua:202
msgid "Hidden in the Depths"
msgstr "Celati in Profondità"

#: mods/HUD/mcl_achievements/init.lua:203
msgid "Pick up an Ancient Debris from the floor."
msgstr "Raccogli dei Detriti Antichi dal pavimento."

#: mods/HUD/mcl_achievements/init.lua:210
msgid "The Next Generation"
msgstr "La Nuova Generazione"

#: mods/HUD/mcl_achievements/init.lua:211
msgid ""
"Hold the Dragon Egg.\n"
"Hint: Pick up the egg from the ground and have it in your inventory."
msgstr ""
"Impugna l'Uovo di Drago\n"
"Suggerimento: Raccogli l'uovo dal pavimento e mettilo net tuo inventario."

#: mods/HUD/mcl_achievements/init.lua:218
msgid "Sky's the Limit"
msgstr "Nel Blu Dipinto di Blu"

#: mods/HUD/mcl_achievements/init.lua:219
msgid "Find the elytra and prepare to fly above and beyond!"
msgstr "Trova le elitre e preparati a volare al di sopra ed oltre!"

#: mods/HUD/mcl_achievements/init.lua:228
msgid "Acquire Hardware"
msgstr "Ferri del Mestiere"

#: mods/HUD/mcl_achievements/init.lua:229
msgid ""
"Take an iron ingot from a furnace's output slot.\n"
"Hint: To smelt an iron ingot, put a fuel (like coal) and iron ore into a "
"furnace."
msgstr ""
"Prendi un lingotto di ferro dallo scompartimento d'uscita di una fornace.\n"
"Suggerimento: Per forgiare un lingotto di ferro, alimenta una fornace con un "
"carburante (come del carbone) e mettici del ferro grezzo."

#: mods/HUD/mcl_achievements/init.lua:235
msgid "Delicious Fish"
msgstr "Pesce Delizioso"

#: mods/HUD/mcl_achievements/init.lua:236
msgid ""
"Take any cooked fish after cooking it in a furnace, smoker, campfire or soul "
"campfire.\n"
"Hint: Use a fishing rod to catch a fish and cook it in a furnace."
msgstr ""
"Raccogli qualsiasi tipo di pesce cotto dopo averlo cucinato in una fornace, "
"affumicatore o fuoco da campo.\n"
"Suggerimento: Usa una canna da pesca per pescare un pesce e cuocilo."

#: mods/HUD/mcl_achievements/init.lua:246
msgid "On A Rail"
msgstr "Su un binario"

#: mods/HUD/mcl_achievements/init.lua:247
msgid ""
"Travel by minecart for at least 1000 meters from your starting point in a "
"single ride."
msgstr ""
"Viaggia su un carrello da miniera per almeno 1000 metri dal punto di "
"partenza in un solo giro."

#: mods/HUD/mcl_achievements/init.lua:255
msgid "Sniper Duel"
msgstr "Duello Tra Cecchini"

#: mods/HUD/mcl_achievements/init.lua:257
msgid ""
"Kill a skeleton, wither skeleton or stray by bow and arrow from a distance "
"of at least 20 meters."
msgstr ""
"Uccidi uno scheletro, uno scheletro wither od un errante tramite arco e "
"frecce da una distanza di almeno 20 metri."

#: mods/HUD/mcl_achievements/init.lua:267
msgid "Monster Hunter"
msgstr "Cacciatore di Mostri"

#: mods/HUD/mcl_achievements/init.lua:268
msgid "Kill a monster."
msgstr "Distruggi un mostro."

#: mods/HUD/mcl_achievements/init.lua:276
msgid "We Need to Go Deeper"
msgstr "Lasciate Ogni Speranza..."

#: mods/HUD/mcl_achievements/init.lua:277
msgid "Use obsidian and a fire starter to construct a Nether portal."
msgstr ""
"Utilizza dell'ossidiana ed un acciarino per costruire un portale del Nether."

#: mods/HUD/mcl_achievements/init.lua:284
msgid "The End?"
msgstr "Fine?"

#: mods/HUD/mcl_achievements/init.lua:285
msgid ""
"Or the beginning?\n"
"Hint: Enter an end portal."
msgstr ""
"Sarà davvero la fine?\n"
"Suggerimento: Entra in un portale dell'End."

#: mods/HUD/mcl_achievements/init.lua:292
msgid "The Nether"
msgstr "Il Nether"

#: mods/HUD/mcl_achievements/init.lua:293
msgid ""
"Bring summer clothes.\n"
"Hint: Enter the Nether."
msgstr ""
"Portati dei vestiti leggeri.\n"
"Suggerimento: Entra nel Nether."

#: mods/HUD/mcl_achievements/init.lua:301
msgid "Postmortal"
msgstr "Ciò Che È Morto Non Muoia Mai"

#: mods/HUD/mcl_achievements/init.lua:302
msgid "Use a Totem of Undying to cheat death."
msgstr "Usa un Totem dell'Immortalità per sfuggire alla morte."

#: mods/HUD/mcl_achievements/init.lua:310
msgid "Sweet Dreams"
msgstr "Sogni d'oro"

#: mods/HUD/mcl_achievements/init.lua:311
msgid "Sleep in a bed to change your respawn point."
msgstr "Dormi in un letto per cambiare il tuo punto di generazione."

#: mods/HUD/mcl_achievements/init.lua:318
msgid "Not Quite \"Nine\" Lives"
msgstr "Sette Vite (O Quasi)"

#: mods/HUD/mcl_achievements/init.lua:319
msgid "Charge a Respawn Anchor to the maximum."
msgstr "Carica un'Ancora della Generazione al massimo."

#: mods/HUD/mcl_achievements/init.lua:327
msgid "What A Deal!"
msgstr "Un Uomo Chiamato Contratto!"

#: mods/HUD/mcl_achievements/init.lua:328
msgid "Successfully trade with a Villager."
msgstr "Completa uno scambio con un Villico."

#: mods/HUD/mcl_achievements/init.lua:335
msgid "Tactical Fishing"
msgstr "Pesca Tattica"

#: mods/HUD/mcl_achievements/init.lua:336
msgid "Catch a fish... without a fishing rod!"
msgstr "Pesca un pesce... senza canna da pesca!"

#: mods/HUD/mcl_achievements/init.lua:343
msgid "The Cutest Predator"
msgstr "Il Predatore Più Adorabile"

#: mods/HUD/mcl_achievements/init.lua:344
msgid "Catch an Axolotl with a bucket!"
msgstr "Cattura un Axolotl con un secchio!"

#: mods/HUD/mcl_achievements/init.lua:351
msgid "Withering Heights"
msgstr "Dr. Witherstein"

#: mods/HUD/mcl_achievements/init.lua:352
msgid "Summon the wither from the dead."
msgstr "Evoca il Wither dal regno dei morti."

#: mods/HUD/mcl_achievements/init.lua:359
msgid "Free the End"
msgstr "L'End Liberato"

#: mods/HUD/mcl_achievements/init.lua:360
msgid "Kill the ender dragon. Good Luck!"
msgstr "Uccidi l'Enderdrago. Buona fortuna!"

#: mods/HUD/mcl_achievements/init.lua:368
msgid "Fishy Business"
msgstr "Grazie per tutto il pesce"

#: mods/HUD/mcl_achievements/init.lua:369
msgid ""
"Catch a fish.\n"
"Hint: Catch a fish, salmon, clownfish, or pufferfish."
msgstr ""
"Pesca un pesce.\n"
"Suggerimento: Pesca un pesce, un salmone, un pesce pagliaccio od un pesce "
"palla."

#: mods/HUD/mcl_achievements/init.lua:377
msgid "Country Lode, Take Me Home"
msgstr "La Diritta Via Non È Smarrita"

#: mods/HUD/mcl_achievements/init.lua:378
msgid "Use a compass on a Lodestone."
msgstr "Usa una bussola su della Magnetite."

#: mods/HUD/mcl_achievements/init.lua:386
msgid "Serious Dedication"
msgstr "Dedizione Seria"

#: mods/HUD/mcl_achievements/init.lua:387
msgid ""
"Use a Netherite Ingot to upgrade a hoe, and then completely reevaluate your "
"life choices."
msgstr ""
"Usa un Lingotto di Netherite per migliorare una zappa e poi rivaluta "
"completamente le tue scelte di vita."

#: mods/HUD/mcl_achievements/init.lua:395
msgid "Local Brewery"
msgstr "Distilleria Artigianale"

#: mods/HUD/mcl_achievements/init.lua:396
msgid ""
"Brew a Potion.\n"
"Hint: Take a potion or glass bottle out of the brewing stand."
msgstr ""
"Prepara una pozione.\n"
"Suggerimento: Prendi una pozione od una ampolla da un alambicco."

#: mods/HUD/mcl_achievements/init.lua:404
msgid "Enchanter"
msgstr "L'Apprendista Stregone"

#: mods/HUD/mcl_achievements/init.lua:405
msgid "Enchant an item using an Enchantment Table."
msgstr "Incanta un oggetto tramite un Tavolo per Incantesimi."

#: mods/HUD/mcl_achievements/init.lua:413
msgid "Bring Home the Beacon"
msgstr "Sia Fatta la Luce"

#: mods/HUD/mcl_achievements/init.lua:414
msgid "Use a beacon."
msgstr "Piazza un faro."

#: mods/HUD/mcl_achievements/init.lua:421
msgid "Beaconator"
msgstr "Guardiano del Faro"

#: mods/HUD/mcl_achievements/init.lua:422
msgid "Use a fully powered beacon."
msgstr "Alimenta al massimo un faro."

#: mods/HUD/mcl_achievements/init.lua:430
msgid "The End... Again..."
msgstr "A volte... ritornano..."

#: mods/HUD/mcl_achievements/init.lua:431
msgid "Respawn the Ender Dragon."
msgstr "Evoca nuovamente l'Enderdrago."

#: mods/HUD/mcl_achievements/init.lua:439
msgid "Bee Our Guest"
msgstr "Zzzei il Benvenuto!"

#: mods/HUD/mcl_achievements/init.lua:440
msgid ""
"Use a campfire to collect a bottle of honey from a beehive without "
"aggrivating the bees inside."
msgstr ""
"Usa un fuoco da campo per raccogliere del miele da un alveare con un'ampolla "
"senza innervosire le api all'interno."

#: mods/HUD/mcl_achievements/init.lua:447
msgid "Total Beelocation"
msgstr "Alveare Tascabile"

#: mods/HUD/mcl_achievements/init.lua:448
msgid "Move a bee nest, with 3 bees inside, using a silk touch enchanted tool."
msgstr ""
"Sposta un alveare con 3 api all'interno, utilizzando un utensile incantato "
"con tocco di velluto."

#: mods/HUD/mcl_achievements/init.lua:459
msgid "Wax On"
msgstr "Dai la Cera"

#: mods/HUD/mcl_achievements/init.lua:460
msgid "Apply honeycomb to a copper block to protect it from the elements."
msgstr "Applica la cera a un blocco di rame per proteggerlo dagli elementi."

#: mods/HUD/mcl_achievements/init.lua:467
msgid "Wax Off"
msgstr "Togli la Cera"

#: mods/HUD/mcl_achievements/init.lua:468
msgid "Scrape wax off of a copper block."
msgstr "Raschia della cera da un blocco di rame."

#: mods/HUD/mcl_achievements/init.lua:476
msgid "Crafting a New Look"
msgstr "Motivo di Gelosia"

#: mods/HUD/mcl_achievements/init.lua:477
msgid "Craft a trimmed armor at a Smithing Table"
msgstr "Assembla un'armatura intagliata ad un Banco da Forgiatura"

#: mods/HUD/mcl_achievements/init.lua:484
msgid "Smithing with Style"
msgstr "La Classe dell'Armatura"

#: mods/HUD/mcl_achievements/init.lua:485
msgid ""
"Apply these smithing templates at least once: Spire, Snout, Rib, Ward, "
"Silence, Vex, Tide, Wayfinder"
msgstr ""
"Applica questi modelli di forgiaturaalmeno una volta: Spire, Snout, Rib, "
"Ward, Silence, Vex, Tide, Wayfinder"

#: mods/HUD/mcl_achievements/init.lua:499
msgid "Dispense With This"
msgstr "Grande Distribuzione"

#: mods/HUD/mcl_achievements/init.lua:500
msgid "Place a dispenser."
msgstr "Piazza un distributore."

#: mods/HUD/mcl_achievements/init.lua:511
msgid "Pork Chop"
msgstr "Costoletta di Maiale Cotta"

#: mods/HUD/mcl_achievements/init.lua:512
msgid "Eat a cooked porkchop."
msgstr "Mangia una costoletta di maiale cotta."

#: mods/HUD/mcl_achievements/init.lua:521
msgid "Rabbit Season"
msgstr "Stagione del Coniglio"

#: mods/HUD/mcl_achievements/init.lua:523
msgid "Eat a cooked rabbit."
msgstr "Mangia un coniglio cotto."

#: mods/HUD/mcl_achievements/init.lua:531
msgid "Iron Belly"
msgstr "Stomaco d'Acciaio"

#: mods/HUD/mcl_achievements/init.lua:532
msgid "Get really desperate and eat rotten flesh."
msgstr "Diventa veramente disperato e mangia della carne marcia."

#: mods/HUD/mcl_achievements/init.lua:541
msgid "Pot Planter"
msgstr "Che Vaso!"

#: mods/HUD/mcl_achievements/init.lua:542
msgid "Place a flower pot."
msgstr "Piazza un vaso da fiori."

#: mods/HUD/mcl_achievements/init.lua:552
msgid "The Haggler"
msgstr "Negoziatore"

#: mods/HUD/mcl_achievements/init.lua:553
msgid "Mine emerald ore."
msgstr "Scava del minerale di smeraldo."

#: mods/HUD/mcl_achievements/init.lua:573
msgid "Stone Age"
msgstr "Età della Pietra"

#: mods/HUD/mcl_achievements/init.lua:574
msgid "Mine a stone with new pickaxe."
msgstr "Scava della roccia con il tuo nuovo piccone."

#: mods/HUD/mcl_achievements/init.lua:580
msgid "Hot Stuff"
msgstr "A Qualcuno Piace Caldo"

#: mods/HUD/mcl_achievements/init.lua:581
msgid "Put lava in a bucket."
msgstr "Riempi un secchio con della lava."

#: mods/HUD/mcl_achievements/init.lua:587
msgid "Ice Bucket Challenge"
msgstr "Vetro di Drago"

#: mods/HUD/mcl_achievements/init.lua:588
msgid "Obtain an obsidian block."
msgstr "Ottieni un blocco di ossidiana."

#: mods/HUD/mcl_achievements/init.lua:595
msgid "Hero of the Village"
msgstr "Eroe del Villagio"

#: mods/HUD/mcl_achievements/init.lua:596
msgid "Successfully defend a village from a raid"
msgstr "Proteggi un villaggio da un'incursione"

#: mods/HUD/mcl_achievements/init.lua:605
msgid "Voluntary Exile"
msgstr "Esilio Volontario"

#: mods/HUD/mcl_achievements/init.lua:606
msgid ""
"Kill a raid captain. Maybe consider staying away from the local villages for "
"the time being..."
msgstr ""
"Uccidi il capitano di un'incursione. Forse, per il momento, ti conviene "
"stare alla larga dai villaggi locali..."

#: mods/HUD/mcl_achievements/init.lua:614
msgid "Return to Sender"
msgstr ""

#: mods/HUD/mcl_achievements/init.lua:615
msgid "Destroy a Ghast with a Fireball"
msgstr ""

#: mods/HUD/mcl_achievements/init.lua:623
msgid "Zombie Doctor"
msgstr "Medico degli zombi"

#: mods/HUD/mcl_achievements/init.lua:624
msgid ""
"Use a golden apple on a zombie villager under the Weakness effect; the "
"advancement is granted when the zombie villager converts into a villager."
msgstr ""
"Usa una mela d'oro su un villico zombi in status Debolezza; l'avanzamento "
"verrà assegnato quando il villico zombi si trasforma in un villico."

#: mods/HUD/mcl_achievements/init.lua:634
msgid "A Terrible Fortress"
msgstr ""

#: mods/HUD/mcl_achievements/init.lua:635
msgid "Break your way into a Nether Fortress"
msgstr ""

