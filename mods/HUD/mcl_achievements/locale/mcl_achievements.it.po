msgid "The City at the End of the Game"
msgstr ""

#: mods/HUD/mcl_achievements/init.lua:659
msgid "Go on in, what could happen?"
msgstr ""

#: mods/HUD/mcl_achievements/init.lua:670
msgid "Those Were The Days"
msgstr ""

#: mods/HUD/mcl_achievements/init.lua:671
msgid "Enter a Bastion Remnant"
msgstr ""

