msgid "Mineclonia: Trial(s) edition"
msgstr ""

#: mods/HUD/mcl_achievements/init.lua:683
msgid "Step foot in a Trial Chamber"
msgstr ""

#: mods/HUD/mcl_achievements/init.lua:695
msgid "A Throwaway Joke"
msgstr ""

#: mods/HUD/mcl_achievements/init.lua:696
msgid ""
"Throw a Trident at something.\n"
"Note: Throwing away your only weapon is not a good idea."
msgstr ""

#: mods/HUD/mcl_achievements/init.lua:704
msgid "Very Very Frightening"
msgstr ""

#: mods/HUD/mcl_achievements/init.lua:705
msgid "Strike a Villager with lightning."
msgstr ""
