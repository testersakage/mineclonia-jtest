#: mods/HUD/mcl_death_messages/init.lua:128
msgid "@1 went off with a bang due to a firework fired by @2 from @3"
msgstr "@2 paukautti pelaajan @1 ilotulitteella välineenään @3"

#: mods/HUD/mcl_death_messages/init.lua:131
msgid "@1 was poked to death by a sweet berry bush"
msgstr "@1 juuttui marjapensaaseen"

#: mods/HUD/mcl_death_messages/init.lua:132
msgid "@1 was poked to death by a sweet berry bush whilst trying to escape @2"
msgstr "@1 juuttui marjapensaaseen yrittäessään paeta olentoa @2"

#: mods/HUD/mcl_death_messages/init.lua:135
msgid "@1 froze to death"
msgstr "@1 jäätyi kuoliaaksi"

#: mods/HUD/mcl_death_messages/init.lua:136
msgid "@1 was frozen to death by @2"
msgstr "@2 jäädytti pelaajan @1 kuoliaaksi"

#: mods/HUD/mcl_death_messages/init.lua:139
msgid "@1 was impaled by @2"
msgstr "@2 lävisti pelaajan @1"

#: mods/HUD/mcl_death_messages/init.lua:140
msgid "@1 was impaled by @2 with @3"
msgstr "@2 lävisti pelaajan @1 välineenään @3"
