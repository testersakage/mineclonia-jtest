msgstr "@1 утонул(а), убегая от @2"

#: mods/HUD/mcl_death_messages/init.lua:36
msgid "@1 starved to death"
msgstr "@1 умер(ла) от голода"

#: mods/HUD/mcl_death_messages/init.lua:37
msgid "@1 starved to death whilst fighting @2"
msgstr "@1 умер(ла) от голода, сражаясь с @2"

#: mods/HUD/mcl_death_messages/init.lua:40
msgid "@1 was pricked to death"
msgstr "@1 заколот(а) до смерти"

#: mods/HUD/mcl_death_messages/init.lua:41
msgid "@1 walked into a cactus whilst trying to escape @2"
msgstr "@1 задел(а) кактус, убегая от @2"

#: mods/HUD/mcl_death_messages/init.lua:44
