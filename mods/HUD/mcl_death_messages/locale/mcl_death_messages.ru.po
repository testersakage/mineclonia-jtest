#: mods/HUD/mcl_death_messages/init.lua:90
msgid "@1 was squashed by a falling block whilst fighting @2"
msgstr "@1 раздавлен(а) падающим блоком, сражаясь с @2"

#: mods/HUD/mcl_death_messages/init.lua:93
#: mods/HUD/mcl_death_messages/init.lua:97
msgid "@1 was slain by @2"
msgstr "@1 погиб(ла) от @2"

#: mods/HUD/mcl_death_messages/init.lua:94
#: mods/HUD/mcl_death_messages/init.lua:98
msgid "@1 was slain by @2 using @3"
msgstr "@2 убил(а) @1 с помощью своего @3"

#: mods/HUD/mcl_death_messages/init.lua:101
msgid "@1 was shot by @2"
