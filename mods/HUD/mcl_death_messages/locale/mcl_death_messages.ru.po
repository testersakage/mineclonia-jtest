#: mods/HUD/mcl_death_messages/init.lua:74
msgid "@1 was roasted in dragon breath by @2"
msgstr "@1 поджарился(ась) в драконьем дыхании, благодаря @2"

#: mods/HUD/mcl_death_messages/init.lua:77
msgid "@1 withered away"
