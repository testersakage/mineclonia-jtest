msgid "@1 suffocated in a wall whilst fighting @2"
msgstr "@1 задохнулся(ась) в стене, сражаясь с @2"

#: mods/HUD/mcl_death_messages/init.lua:32
msgid "@1 drowned"
msgstr "@1 утонул(а)"

#: mods/HUD/mcl_death_messages/init.lua:33
