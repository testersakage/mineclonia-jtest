#: mods/HUD/mcl_death_messages/init.lua:45
msgid "@1 hit the ground too hard whilst trying to escape @2"
msgstr "@1 слишком сильно ударился(ась) об землю, убегая от @2"

#: mods/HUD/mcl_death_messages/init.lua:55
msgid "@1 experienced kinetic energy"
msgstr "@1 испытал(а) на себе кинетическую энергию"

#: mods/HUD/mcl_death_messages/init.lua:56
msgid "@1 experienced kinetic energy whilst trying to escape @2"
msgstr "@1 испытал(а) на себе кинетическую энергию, убегая от @2"

#: mods/HUD/mcl_death_messages/init.lua:59
