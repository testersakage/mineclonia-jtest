msgstr "@1 выпал(а) из мира"

#: mods/HUD/mcl_death_messages/init.lua:60
msgid "@1 didn't want to live in the same world as @2"
msgstr "@1 не захотел(а) жить в том же мире, что и @2"

#: mods/HUD/mcl_death_messages/init.lua:63
msgid "@1 died"
