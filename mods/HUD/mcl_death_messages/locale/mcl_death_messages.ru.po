#: mods/HUD/mcl_death_messages/init.lua:102
msgid "@1 was shot by @2 using @3"
msgstr "@2 застрелил(а) @1 с помощью своего @3"

#: mods/HUD/mcl_death_messages/init.lua:105
msgid "@1 was spitballed by @2"
