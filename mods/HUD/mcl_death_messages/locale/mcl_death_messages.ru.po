#: mods/HUD/mcl_death_messages/init.lua:78
msgid "@1 withered away whilst fighting @2"
msgstr "@1 иссох(ла), сражаясь с @2"

#: mods/HUD/mcl_death_messages/init.lua:82
msgid "@1 was shot by a skull from @2"
