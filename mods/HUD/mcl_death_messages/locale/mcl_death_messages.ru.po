#: mods/HUD/mcl_death_messages/init.lua:85
msgid "@1 was squashed by a falling anvil"
msgstr "@1 раздавлен(а) падающей наковальней"

#: mods/HUD/mcl_death_messages/init.lua:86
msgid "@1 was squashed by a falling anvil whilst fighting @2"
msgstr "@1 раздавлен(а) падающей наковальней, сражаясь с @2"

#: mods/HUD/mcl_death_messages/init.lua:89
