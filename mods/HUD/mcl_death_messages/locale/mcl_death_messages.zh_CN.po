#: mods/HUD/mcl_death_messages/init.lua:8
msgid "@1 went up in flames"
msgstr "@1在火焰中化为灰烬"

#: mods/HUD/mcl_death_messages/init.lua:9
msgid "@1 walked into fire whilst fighting @2"
msgstr "与@2战斗时，@1引火烧身"

#: mods/HUD/mcl_death_messages/init.lua:12
msgid "@1 was struck by lightning"
msgstr "闪电击中了@1"

#: mods/HUD/mcl_death_messages/init.lua:13
msgid "@1 was struck by lightning whilst fighting @2"
msgstr "@1在与@2战斗时被闪电击中"

#: mods/HUD/mcl_death_messages/init.lua:16
msgid "@1 burned to death"
msgstr "@1被烧死"

#: mods/HUD/mcl_death_messages/init.lua:17
msgid "@1 was burnt to a crisp whilst fighting @2"
msgstr "@1在与@2战斗时被烧得焦黑"

#: mods/HUD/mcl_death_messages/init.lua:20
msgid "@1 tried to swim in lava"
