msgstr "Antaa pelaajalle kokemuspisteitä"

msgid "Error: Too many parameters!"
msgstr "Virhe: Liian monta muuttujaa!"

msgid "Error: Incorrect value of XP"
msgstr "Virhe: Virheellinen kokemuspisteiden lukumäärä"

msgid "Error: Player not found"
msgstr "Virhe: Pelaajaa ei löydetty"

msgid "Added @1 XP to @2, total: @3, experience level: @4"
msgstr "Lisätty @1 kokemuspistettä pelaajalle @2, yhteensä: @3, kokemustaso: @4"
