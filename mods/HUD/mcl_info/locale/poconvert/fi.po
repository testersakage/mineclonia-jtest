msgid "Set debug bit mask: 0 = disable, 1 = player coords, 2 = coordinates, 3 = biome name, 4 = all"
msgstr ""
"Aseta näytöllä näkyvät tiedot: 0 = pois päältä, 1 = pelaajakoordinaatit, 2 = "
"koordinaatit, 3 = biomin nimi, 4 = kaikki"

msgid "<bitmask>"
msgstr "<näytettäviä tietoja ilmaiseva kokonaisluku>"

msgid "Error! Possible values are integer numbers from @1 to @2"
msgstr "Virhe! Mahdolliset arvot ovat kokonaisluvut väliltä @1 ja @2"

msgid "Set location bit mask: 0 = disable, 1 = coordinates"
msgstr "Aseta näytettävät sijaintitiedot: 0 = pois päältä, 1 = koordinaatit"
