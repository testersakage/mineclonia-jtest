msgid "Set debug bit mask: 0 = disable, 1 = player coords, 2 = coordinates, 3 = biome name, 4 = all"
msgstr ""
"Définir le masque de bits de débogage : 0 = désactivé, 1 = coordonnées du "
"joueur, 2 = coordonnées, 3 = nom du biome, 4 = tout"

msgid "<bitmask>"
msgstr "<bitmask>"

msgid "Error! Possible values are integer numbers from @1 to @2"
msgstr "Erreur ! Les valeurs possibles sont des nombres entiers de @1 à @2"

msgid "Set location bit mask: 0 = disable, 1 = coordinates"
msgstr ""
"Définir le masque de bits de l'emplacement : 0 = désactivé, 1 = coordonnées"
