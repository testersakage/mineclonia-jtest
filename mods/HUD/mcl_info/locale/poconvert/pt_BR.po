msgid "Set debug bit mask: 0 = disable, 1 = player coords, 2 = coordinates, 3 = biome name, 4 = all"
msgstr ""
"Defina a máscara de bits para depuração: 0 = desativar, 1 = coordenadas do "
"jogador, 2 = coordenadas, 3 = nome do bioma, 4 = todos"

msgid "<bitmask>"
msgstr "<bitmask>"

msgid "Error! Possible values are integer numbers from @1 to @2"
msgstr "Erro! Os valores possíveis são números inteiros de @1 a @2"

msgid "Set location bit mask: 0 = disable, 1 = coordinates"
msgstr ""
"Definir máscara de bits de localização: 0 = desabilitar, 1 = coordenadas"
