msgid "Set debug bit mask: 0 = disable, 1 = player coords, 2 = coordinates, 3 = biome name, 4 = all"
msgstr ""
"Установить отладочную битовую маску: 0 = отключено, 1 = коорд-ты игрока, 2 = "
"координаты, 3 = имя биома, 4 = всё"

msgid "<bitmask>"
msgstr "<битовая_маска>"

msgid "Error! Possible values are integer numbers from @1 to @2"
msgstr "Ошибка! Допустимые значения: целые числа от @1 до @2"

msgid "Set location bit mask: 0 = disable, 1 = coordinates"
msgstr "Установить битовую маску локации: 0 = отключено, 1 = координаты"
