#: mods/ITEMS/mcl_amethyst/init.lua:10
msgid "Block of Amethyst"
msgstr "Bloque de amatista"

#: mods/ITEMS/mcl_amethyst/init.lua:11
msgid ""
"The Block of Amethyst is a decoration block crafted from amethyst shards."
msgstr ""
"El Bloque de Amatista es un bloque decorativo fabricado a partir de "
"fragmentos de amatista."

#: mods/ITEMS/mcl_amethyst/init.lua:19
msgid "Budding Amethyst"
msgstr "Brotador de amatista"

#: mods/ITEMS/mcl_amethyst/init.lua:20
msgid "The Budding Amethyst can grow amethyst"
msgstr "El Brotador de amatista puede hacer crecer amatista"

#: mods/ITEMS/mcl_amethyst/init.lua:34
msgid "Amethyst Shard"
msgstr "Fragmento de amatista"

#: mods/ITEMS/mcl_amethyst/init.lua:35
msgid "An amethyst shard is a crystalline mineral."
msgstr "Un fragmento de amatista es un mineral cristalino."

#: mods/ITEMS/mcl_amethyst/init.lua:39
msgid "Amethyst Material"
msgstr ""

#: mods/ITEMS/mcl_amethyst/init.lua:45
msgid "Calcite"
msgstr "Calcita"

#: mods/ITEMS/mcl_amethyst/init.lua:46
msgid "Calcite can be found as part of amethyst geodes."
msgstr "La Calcita se puede encontrar como parte de las geodas de amatista."

#: mods/ITEMS/mcl_amethyst/init.lua:55
msgid "Tinted Glass"
msgstr "Cristal opaco"

#: mods/ITEMS/mcl_amethyst/init.lua:56
msgid ""
"Tinted Glass is a type of glass which blocks lights while it is visually "
"transparent."
msgstr ""
"El Cristal Opaco es un tipo de cristal que bloquea la luz mientras es "
"visualmente transparente."

#: mods/ITEMS/mcl_amethyst/init.lua:70
msgid "Small Amethyst Bud"
msgstr "Brote de amatista pequeño"

#: mods/ITEMS/mcl_amethyst/init.lua:71
msgid "Small Amethyst Bud is the first growth of amethyst bud."
msgstr ""
"El brote de amatista pequeño es la primera etapa de crecimiento del brote de "
"amatista."

#: mods/ITEMS/mcl_amethyst/init.lua:80
msgid "Medium Amethyst Bud"
msgstr "Brote de amatista mediano"

#: mods/ITEMS/mcl_amethyst/init.lua:81
msgid "Medium Amethyst Bud is the second growth of amethyst bud."
msgstr ""
"El brote de amatista mediano es la segunda etapa de crecimiento del brote de "
"amatista."

#: mods/ITEMS/mcl_amethyst/init.lua:90
msgid "Large Amethyst Bud"
msgstr "Brote de amatista grande"

#: mods/ITEMS/mcl_amethyst/init.lua:91
msgid "Large Amethyst Bud is the third growth of amethyst bud."
msgstr ""
"El brote de amatista grande es la tercera etapa de crecimiento del brote de "
"amatista."

#: mods/ITEMS/mcl_amethyst/init.lua:127
msgid "Amethyst Cluster"
msgstr "Cúmulo de amatista"

#: mods/ITEMS/mcl_amethyst/init.lua:129
msgid "Amethyst Cluster is the final growth of amethyst bud."
msgstr ""
"El cúmulo de amatista es la etapa final de crecimiento del brote de amatista."
