#: mods/ITEMS/mcl_barrels/init.lua:36 mods/ITEMS/mcl_barrels/init.lua:96
msgid "Barrel"
msgstr "Tonneau"

#: mods/ITEMS/mcl_barrels/init.lua:50
msgid "Inventory"
msgstr "Inventaire"

#: mods/ITEMS/mcl_barrels/init.lua:97 mods/ITEMS/mcl_barrels/init.lua:158
msgid "27 inventory slots"
msgstr "27 emplacements d'inventaire"

#: mods/ITEMS/mcl_barrels/init.lua:98 mods/ITEMS/mcl_barrels/init.lua:159
msgid "Barrels are containers which provide 27 inventory slots."
msgstr ""
"Les tonneaux sont des conteneurs qui offrent 27 emplacements d'inventaire."

#: mods/ITEMS/mcl_barrels/init.lua:99 mods/ITEMS/mcl_barrels/init.lua:160
msgid ""
"To access its inventory, rightclick it. When broken, the items will drop out."
msgstr ""
"Pour accéder à son contenu, faites un clic droit dessus. Détruit, il fera "
"tomber les objets qu'il contenait."

#: mods/ITEMS/mcl_barrels/init.lua:157
msgid "Barrel Open"
msgstr "Tonneau ouvert"
