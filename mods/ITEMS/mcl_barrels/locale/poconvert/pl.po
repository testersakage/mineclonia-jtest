msgid "Barrel"
msgstr "Beczka"

msgid "Inventory"
msgstr "Ekwipunek"

msgid "27 inventory slots"
msgstr "27 miejsc na ekwipunek"

msgid "Barrels are containers which provide 27 inventory slots."
msgstr "Beczki to pojemniki z dwudziestoma siedmioma miejscami na ekwipunek."

msgid "To access its inventory, rightclick it. When broken, the items will drop out."
msgstr ""
"Żeby zobaczyć jej zawartość kliknij prawym przyciskiem. Po zniszczeniu "
"wypadną z niej przedmioty."

msgid "Barrel Open"
msgstr "Otwarta beczka"
