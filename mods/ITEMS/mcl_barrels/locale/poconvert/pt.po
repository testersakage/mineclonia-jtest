msgid "Barrel"
msgstr "Barril"

msgid "Inventory"
msgstr "Inventário"

msgid "27 inventory slots"
msgstr "27 espaços do inventário"

msgid "Barrels are containers which provide 27 inventory slots."
msgstr "Barris são recipientes que fornecem 27 espaços do inventário."

msgid "To access its inventory, rightclick it. When broken, the items will drop out."
msgstr ""
"Para aceder o seu inventário, clique com o direito. Quando quebrado, os "
"items caiem."

msgid "Barrel Open"
msgstr "Barril aberto"
