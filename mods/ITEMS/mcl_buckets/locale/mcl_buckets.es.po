#: mods/ITEMS/mcl_buckets/init.lua:255
msgid "Empty Bucket"
msgstr "Cubo vacío"

#: mods/ITEMS/mcl_buckets/init.lua:256
msgid "A bucket can be used to collect and release liquids."
msgstr "Se puede usar un cubo para recoger y liberar líquidos."

#: mods/ITEMS/mcl_buckets/init.lua:257
msgid ""
"Punch a liquid source to collect it. You can then use the filled bucket to "
"place the liquid somewhere else."
msgstr ""
"Golpea una fuente de líquido para recolectarla. Luego puede usar el cubo "
"lleno para colocar el líquido en otro lugar."

#: mods/ITEMS/mcl_buckets/init.lua:258
msgid "Collects liquids"
msgstr "Recoge líquidos"

#: mods/ITEMS/mcl_buckets/mcl_buckets_translations_tmp.lua:1
msgid "Bucket of Axolotl"
msgstr "Cubo con ajolote"

#: mods/ITEMS/mcl_buckets/mcl_buckets_translations_tmp.lua:2
msgid "Bucket of Cod"
msgstr "Cubo con bacalao"

#: mods/ITEMS/mcl_buckets/mcl_buckets_translations_tmp.lua:3
msgid "Bucket of Pufferfish"
msgstr ""

#: mods/ITEMS/mcl_buckets/mcl_buckets_translations_tmp.lua:4
msgid "Bucket of Salmon"
msgstr "Cubo con salmón"

#: mods/ITEMS/mcl_buckets/mcl_buckets_translations_tmp.lua:5
msgid "Bucket of Tropical Fish"
msgstr "Cubo con pez tropical"

#: mods/ITEMS/mcl_buckets/mcl_buckets_translations_tmp.lua:6
msgid ""
"Place it to empty the bucket and place a Cod. Obtain by right clicking on a "
"Cod with a bucket of water."
msgstr ""
"Colócalo para vaciar el cubo y colocar un Bacalao. Consíguelo haciendo clic "
"derecho sobre un Bacalao con un cubo de agua."

#: mods/ITEMS/mcl_buckets/mcl_buckets_translations_tmp.lua:7
msgid ""
"Place it to empty the bucket and place a Pufferfish. Obtain by right "
"clicking on a Pufferfish with a bucket of water."
msgstr ""

#: mods/ITEMS/mcl_buckets/mcl_buckets_translations_tmp.lua:8
msgid ""
"Place it to empty the bucket and place a Salmon. Obtain by right clicking on "
"a Salmon with a bucket of water."
msgstr ""
"Colócalo para vaciar el cubo y colocar un Salmón. Consíguelo haciendo clic "
"derecho sobre un Salmón con un cubo de agua."

#: mods/ITEMS/mcl_buckets/mcl_buckets_translations_tmp.lua:9
msgid ""
"Place it to empty the bucket and place a Tropical Fish. Obtain by right "
"clicking on a Tropical Fish with a bucket of water."
msgstr ""
"Colócalo para vaciar el cubo y colocar un Pez Tropical. Consíguelo haciendo "
"clic derecho sobre un Pez Tropical con un cubo de agua."

#: mods/ITEMS/mcl_buckets/mcl_buckets_translations_tmp.lua:10
msgid ""
"Place it to empty the bucket and place an Axolotl. Obtain by right clicking "
"on an Axolotl with a bucket of water."
msgstr ""
"Colócalo para vaciar el cubo y colocar un Ajolote. Consíguelo haciendo clic "
"derecho sobre un Ajolote con un cubo de agua."

#: mods/ITEMS/mcl_buckets/mcl_buckets_translations_tmp.lua:11
msgid "Places a water source and a Cod."
msgstr "Coloca una fuente de agua y un Bacalao."

#: mods/ITEMS/mcl_buckets/mcl_buckets_translations_tmp.lua:12
msgid "Places a water source and a Pufferfish."
msgstr ""

#: mods/ITEMS/mcl_buckets/mcl_buckets_translations_tmp.lua:13
msgid "Places a water source and a Salmon."
msgstr "Coloca una fuente de agua y un Salmón."

#: mods/ITEMS/mcl_buckets/mcl_buckets_translations_tmp.lua:14
msgid "Places a water source and a Tropical Fish."
msgstr "Coloca una fuente de agua y un Pez Tropical."

#: mods/ITEMS/mcl_buckets/mcl_buckets_translations_tmp.lua:15
msgid "Places a water source and an Axolotl."
msgstr "Coloca una fuente de agua y un Ajolote."

#: mods/ITEMS/mcl_buckets/mcl_buckets_translations_tmp.lua:16
msgid "This bucket is filled with water and a Cod."
msgstr "Este cubo está lleno con agua y un Bacalao."

#: mods/ITEMS/mcl_buckets/mcl_buckets_translations_tmp.lua:17
msgid "This bucket is filled with water and a Pufferfish."
msgstr ""

#: mods/ITEMS/mcl_buckets/mcl_buckets_translations_tmp.lua:18
msgid "This bucket is filled with water and a Salmon."
msgstr "Este cubo está lleno con agua y un Salmón."

#: mods/ITEMS/mcl_buckets/mcl_buckets_translations_tmp.lua:19
msgid "This bucket is filled with water and a Tropical Fish."
msgstr "Este cubo está lleno con agua y un Pez Tropical."

#: mods/ITEMS/mcl_buckets/mcl_buckets_translations_tmp.lua:20
msgid "This bucket is filled with water and an Axolotl."
msgstr "Este cubo está lleno con agua y un Ajolote."

#: mods/ITEMS/mcl_buckets/register.lua:22
msgid "Lava Bucket"
msgstr "Cubo con lava"

#: mods/ITEMS/mcl_buckets/register.lua:23
msgid ""
"A bucket can be used to collect and release liquids. This one is filled with "
"hot lava, safely contained inside. Use with caution."
msgstr ""
"Se puede usar un cubo para recoger y liberar líquidos. Este está lleno de "
"lava caliente, contenida de forma segura en el interior. Usar con precaución."

#: mods/ITEMS/mcl_buckets/register.lua:24
msgid ""
"Get in a safe distance and place the bucket to empty it and create a lava "
"source at this spot. Don't burn yourself!"
msgstr ""
"Aléjate a una distancia segura y coloca el cubo para vaciarlo y crea una "
"fuente de lava en este lugar. ¡No te quemes!"

#: mods/ITEMS/mcl_buckets/register.lua:25
msgid "Places a lava source"
msgstr "Coloca una fuente de lava"

#: mods/ITEMS/mcl_buckets/register.lua:37
msgid "Water Bucket"
msgstr "Cubo con agua"

#: mods/ITEMS/mcl_buckets/register.lua:38
msgid ""
"A bucket can be used to collect and release liquids. This one is filled with "
"water."
msgstr ""
"Se puede usar un cubo para recoger y liberar líquidos. Este está lleno de "
"agua."

#: mods/ITEMS/mcl_buckets/register.lua:39
msgid "Place it to empty the bucket and create a water source."
msgstr "Colóquelo para vaciar el cubo y crear una fuente de agua."

#: mods/ITEMS/mcl_buckets/register.lua:40
msgid "Places a water source"
msgstr "Coloca una fuente de agua"

#: mods/ITEMS/mcl_buckets/register.lua:58
msgid "River Water Bucket"
msgstr "Cubo de agua de río"

#: mods/ITEMS/mcl_buckets/register.lua:59
msgid ""
"A bucket can be used to collect and release liquids. This one is filled with "
"river water."
msgstr ""
"Se puede usar un cubo para recoger y liberar líquidos. Este está lleno de "
"agua de río."

#: mods/ITEMS/mcl_buckets/register.lua:60
msgid "Place it to empty the bucket and create a river water source."
msgstr "Colóquelo para vaciar el cubo y crear una fuente de agua de río."

#: mods/ITEMS/mcl_buckets/register.lua:61
msgid "Places a river water source"
msgstr "Coloca una fuente de agua de río"
