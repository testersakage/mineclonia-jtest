#: mods/ITEMS/mcl_buckets/init.lua:255
msgid "Empty Bucket"
msgstr "Üres Vödör"

#: mods/ITEMS/mcl_buckets/init.lua:256
msgid "A bucket can be used to collect and release liquids."
msgstr "A vödörrel folyadékot szállíthatsz és önthetsz ki."

#: mods/ITEMS/mcl_buckets/init.lua:257
msgid ""
"Punch a liquid source to collect it. You can then use the filled bucket to "
"place the liquid somewhere else."
msgstr ""
"Üss meg egy folyadékforrást a begyűjtéshez. Ezután a teli vödör segítségével "
"elhelyezheted a folyadékot valahol máshol."

#: mods/ITEMS/mcl_buckets/init.lua:258
msgid "Collects liquids"
msgstr "Folyadékot gyűjt be"

