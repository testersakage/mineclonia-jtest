#: mods/ITEMS/mcl_campfires/api.lua:114 mods/ITEMS/mcl_campfires/api.lua:160
msgid "Cooks food and keeps bees happy."
msgstr "Cocina comida y mantiene a las abejas felices."

#: mods/ITEMS/mcl_campfires/api.lua:115 mods/ITEMS/mcl_campfires/api.lua:161
msgid ""
"Campfires have multiple uses, including keeping bees happy, cooking raw meat "
"and fish, and as a trap."
msgstr ""
"Las fogatas tienen múltiples usos, incluyendo mantener a las abejas felices, "
"cocinar carne cruda y pescado, y como trampa."

