#: mods/ITEMS/mcl_cauldrons/init.lua:149
msgid "Cauldron"
msgstr "炼药锅"

#: mods/ITEMS/mcl_cauldrons/init.lua:150
msgid "Stores water"
msgstr "储存水"

#: mods/ITEMS/mcl_cauldrons/init.lua:151
msgid "Cauldrons are used to store water and slowly fill up under rain."
msgstr "炼药锅用于储存水，并且在下雨时会慢慢被填满。"

#: mods/ITEMS/mcl_cauldrons/init.lua:152
msgid ""
"Place a water bucket into the cauldron to fill it with water. Place an empty "
"bucket on a full cauldron to retrieve the water. Place a water bottle into "
"the cauldron to fill the cauldron to one third with water. Place a glass "
"bottle in a cauldron with water to retrieve one third of the water."
msgstr ""
"把水桶放入炼药锅中使其装满水。把空桶放在装满水的炼药锅上可取回水。把水瓶放入"
"炼药锅中，能让炼药锅内的水增加至三分之一满。把玻璃瓶放在有水的炼药锅中，可取"
"出三分之一的水。在有水的炼药锅上使用有图案的旗帜，可洗掉旗帜的最上层。"

#: mods/ITEMS/mcl_cauldrons/init.lua:241
msgid "Cauldron (@1/3 Water)"
msgstr "炼药锅（@1/3 水）"

#: mods/ITEMS/mcl_cauldrons/init.lua:242
msgid "Cauldron (@1/3 Lava)"
msgstr "炼药锅（@1/3 岩浆）"

#: mods/ITEMS/mcl_cauldrons/init.lua:243
msgid "Cauldron (@1/3 Powder Snow)"
msgstr "炼药锅（@1/3 雪粒）"

#: mods/ITEMS/mcl_cauldrons/init.lua:244
msgid "Cauldron (@1/3 River Water)"
msgstr "炼药锅（@1/3 河水）"
