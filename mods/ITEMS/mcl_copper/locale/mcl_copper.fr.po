#: mods/ITEMS/mcl_copper/items.lua:4
msgid "Copper Ingot"
msgstr "Lingot de cuivre"

#: mods/ITEMS/mcl_copper/items.lua:5
msgid "Molten Copper. It is used to craft armor, tools, and blocks."
msgstr ""
"Du cuivre fondu. Ceci est utilisé pour fabriquer des armures, des outils et "
"des blocs."

#: mods/ITEMS/mcl_copper/items.lua:9
