#: mods/ITEMS/mcl_core/craftitems.lua:4
msgid "Stick"
msgstr "Makila"

#: mods/ITEMS/mcl_core/craftitems.lua:5
msgid ""
"Sticks are a very versatile crafting material; used in countless crafting "
"recipes."
msgstr ""
"Makilak fabrikazio material oso moldakorrak dira; fabrikazio errezeta "
"askotan erabiltzen dira."

#: mods/ITEMS/mcl_core/craftitems.lua:14
msgid "Paper"
msgstr "Papera"

#: mods/ITEMS/mcl_core/craftitems.lua:15
msgid "Paper is used to craft books and maps."
msgstr "Papera liburuak eta mapak egiteko erabiltzen da."

#: mods/ITEMS/mcl_core/craftitems.lua:21
msgid "Coal"
msgstr "Ikatza"

#: mods/ITEMS/mcl_core/craftitems.lua:22
msgid ""
"“Coal” refers to coal lumps obtained by digging coal ore which can be found "
"underground. Coal is your standard furnace fuel, but it can also be used to "
"make torches, coal blocks and a few other things."
msgstr ""
"\"Ikatza\" lurpean aurki daitekeen ikatz minerala hondeatzean lortutako "
"ikatz zatiak dira. Ikatza bere labeko erregai estandarra da, baina argi-"
"zuziak, ikatz blokeak eta beste gauza batzuk egiteko ere erabil daiteke."

#: mods/ITEMS/mcl_core/craftitems.lua:31
msgid "Charcoal"
msgstr "Egur-ikatza"

#: mods/ITEMS/mcl_core/craftitems.lua:32
msgid ""
"Charcoal is an alternative furnace fuel created by cooking wood in a "
"furnace. It has the same burning time as coal and also shares many of its "
"crafting recipes, but it can not be used to create coal blocks."
msgstr ""
"Egur-ikatza labeetarako ordezko erregai bat da, labe batean egurra "
"prestatzean sortzen dena. Ikatzaren errekuntza denbora bera du, eta bere "
"fabrikazio errezeta asko ere partekatzen ditu, baina ezin da ikatz blokeak "
"sortzeko erabili."

#: mods/ITEMS/mcl_core/craftitems.lua:40
msgid "Iron Nugget"
msgstr "Burdinazko pepita"

#: mods/ITEMS/mcl_core/craftitems.lua:41
msgid ""
"Iron nuggets are very small pieces of molten iron; the main purpose is to "
"create iron ingots."
msgstr ""
"Burdina pipitak burdinurtuzko pieza oso txikiak dira; helburu nagusia "
"burdinazko lingoteak sortzea da."

#: mods/ITEMS/mcl_core/craftitems.lua:48
msgid "Gold Nugget"
msgstr "Urrezko pepita"

#: mods/ITEMS/mcl_core/craftitems.lua:49
msgid ""
"Gold nuggets are very small pieces of molten gold; the main purpose is to "
"create gold ingots."
msgstr ""
"Urre pipitak urre urtuzko pieza oso txikiak dira; Helburu nagusia urrezko "
"lingoteak sortzea da."

#: mods/ITEMS/mcl_core/craftitems.lua:56
msgid "Diamond"
msgstr "Diamantea"

#: mods/ITEMS/mcl_core/craftitems.lua:57
msgid ""
"Diamonds are precious minerals and useful to create the highest tier of "
"armor and tools."
msgstr ""
"Diamanteak mineral preziatuak eta erabilgarriak dira armaduraren eta "
"erreminten mailarik altuena sortzeko."

#: mods/ITEMS/mcl_core/craftitems.lua:61
msgid "Diamond Material"
msgstr ""

#: mods/ITEMS/mcl_core/craftitems.lua:66
msgid "Clay Ball"
msgstr "Buztinezko bola"

#: mods/ITEMS/mcl_core/craftitems.lua:67
msgid ""
"Clay balls are a raw material, mainly used to create bricks in the furnace."
msgstr ""
"Buztinezko bolak lehengai bat dira, batez ere labean adreiluak sortzeko "
"erabiltzen dena."

#: mods/ITEMS/mcl_core/craftitems.lua:76
msgid "Iron Ingot"
msgstr "Burdinazko lingotea"

#: mods/ITEMS/mcl_core/craftitems.lua:77
msgid "Molten iron. It is used to craft armor, tools, and whatnot."
msgstr ""
"Burdinurtua. Armadurak, erremintak eta beste gauza batzuk fabrikatzeko "
"erabiltzen da."

#: mods/ITEMS/mcl_core/craftitems.lua:81
msgid "Iron Material"
msgstr ""

#: mods/ITEMS/mcl_core/craftitems.lua:89
msgid "Gold Ingot"
msgstr "Urrezko lingotea"

#: mods/ITEMS/mcl_core/craftitems.lua:90
msgid "Molten gold. It is used to craft armor, tools, and whatnot."
msgstr ""
"Urre urtua Armadurak, erremintak eta beste gauza batzuk egiteko erabiltzen "
"da."

#: mods/ITEMS/mcl_core/craftitems.lua:94
msgid "Gold Material"
msgstr ""

#: mods/ITEMS/mcl_core/craftitems.lua:102
msgid "Emerald"
msgstr "Esmeralda"

#: mods/ITEMS/mcl_core/craftitems.lua:103
msgid "Emeralds are used in villager trades as currency."
msgstr "Esmeraldak baserritarren merkataritzan erabiltzen dira txanpon gisa."

#: mods/ITEMS/mcl_core/craftitems.lua:107
msgid "Emerald Material"
msgstr ""

#: mods/ITEMS/mcl_core/craftitems.lua:112
msgid "Lapis Lazuli"
msgstr "Lapis Lazuli"

#: mods/ITEMS/mcl_core/craftitems.lua:113
msgid "Lapis Lazuli are required for enchanting items on an enchanting table."
msgstr ""
"Lapis Lazuliak beharrezkoak dira sorginkeria mahai batean itemak xarmatzeko."

#: mods/ITEMS/mcl_core/craftitems.lua:117
msgid "Lapis Material"
msgstr ""

#: mods/ITEMS/mcl_core/craftitems.lua:125
msgid "Brick"
msgstr "Adreilua"

#: mods/ITEMS/mcl_core/craftitems.lua:126
msgid "Bricks are used to craft brick blocks."
msgstr "Adreiluak adreilu blokeak egiteko erabiltzen dira."

#: mods/ITEMS/mcl_core/craftitems.lua:133
msgid "Flint"
msgstr "Suharria"

#: mods/ITEMS/mcl_core/craftitems.lua:134
msgid "Flint is a raw material."
msgstr "Suharria lehengai bat da."

#: mods/ITEMS/mcl_core/craftitems.lua:140
msgid "Sugar"
msgstr "Azukrea"

#: mods/ITEMS/mcl_core/craftitems.lua:141
msgid "Sugar comes from sugar canes and is used to make sweet foods."
msgstr ""
"Azukrea azukre kanaberetatik dator, eta elikagai gozoak egiteko erabiltzen "
"da."

#: mods/ITEMS/mcl_core/craftitems.lua:147
msgid "Bowl"
msgstr "Katilua"

#: mods/ITEMS/mcl_core/craftitems.lua:148
msgid "Bowls are mainly used to hold tasty soups."
msgstr "Katiluak zopa gozoak edukitzeko erabiltzen dira batez ere."

#: mods/ITEMS/mcl_core/craftitems.lua:155
msgid "Apple"
msgstr "Sagarra"

#: mods/ITEMS/mcl_core/craftitems.lua:156
msgid "Apples are food items which can be eaten."
msgstr "Sagarrak jan daitezkeen elikagaiak dira."

#: mods/ITEMS/mcl_core/craftitems.lua:165
msgid "Golden Apple"
msgstr "Urrezko sagarra"

#: mods/ITEMS/mcl_core/craftitems.lua:166
#: mods/ITEMS/mcl_core/craftitems.lua:183
msgid "Golden apples are precious food items which can be eaten."
msgstr "Urre koloreko sagarrak jan daitezkeen janari ederrak dira."

#: mods/ITEMS/mcl_core/craftitems.lua:182
msgid "Enchanted Golden Apple"
msgstr "Sagar urreztatu sorgindua"

