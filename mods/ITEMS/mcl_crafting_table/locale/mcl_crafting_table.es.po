#: mods/ITEMS/mcl_crafting_table/init.lua:10
msgid "Crafting"
msgstr "Fabricación"

#: mods/ITEMS/mcl_crafting_table/init.lua:20
msgid "Inventory"
msgstr "Inventario"

#: mods/ITEMS/mcl_crafting_table/init.lua:33
msgid "Recipe book"
msgstr "Libro de recetas"

#: mods/ITEMS/mcl_crafting_table/init.lua:36
msgid "Fill Craft Grid"
msgstr "Rellenar rejilla de fabricación"

#: mods/ITEMS/mcl_crafting_table/init.lua:80
msgid "Crafting Table"
msgstr "Mesa de trabajo"

#: mods/ITEMS/mcl_crafting_table/init.lua:81
msgid "3×3 crafting grid"
msgstr "Cuadrícula de fabricación de 3×3"

#: mods/ITEMS/mcl_crafting_table/init.lua:82
msgid ""
"A crafting table is a block which grants you access to a 3×3 crafting grid "
"which allows you to perform advanced crafts."
msgstr ""
"Una mesa de trabajo es un bloque que le otorga acceso a una cuadrícula de "
"fabricación 3×3 que le permite realizar fabricaciones avanzadas."

#: mods/ITEMS/mcl_crafting_table/init.lua:83
msgid "Rightclick the crafting table to access the 3×3 crafting grid."
msgstr ""
"Haz clic derecho en la mesa de trabajo para acceder a la cuadrícula de "
"fabricación 3×3."
