msgid "Crafting"
msgstr "Создание"

msgid "Inventory"
msgstr "Инвентарь"

msgid "Recipe book"
msgstr "Книга рецептов"

msgid "Fill Craft Grid"
msgstr "Заполнить сетку крафта"

msgid "Crafting Table"
msgstr "Верстак"

msgid "3×3 crafting grid"
msgstr "Сетка крафта 3×3"

msgid "A crafting table is a block which grants you access to a 3×3 crafting grid which allows you to perform advanced crafts."
msgstr ""
"Верстак — это блок с сеткой крафта 3×3, что позволяет использовать "
"продвинутые рецепты."

msgid "Rightclick the crafting table to access the 3×3 crafting grid."
msgstr "Кликните правой кнопкой мыши для получения доступа к сетке крафта 3×3."
