#: mods/ITEMS/mcl_deepslate/deepslate.lua:12
msgid "Deepslate"
msgstr "Arbel sakona"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:13
msgid ""
"Deepslate is a stone type found deep underground in the Overworld that "
"functions similar to regular stone but is harder than the stone."
msgstr ""
"Arbel sakona Lurrazalean sakonean dagoen harri mota bat da, eta harri "
"arruntaren antzera funtzionatzen du, baina hau baino gogorragoa da."

#: mods/ITEMS/mcl_deepslate/deepslate.lua:27
msgid "Infested Deepslate"
msgstr "Arbel sakon infestatua"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:31
msgid "Reinforced Deepslate"
msgstr "Arbel sakon indartua"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:32
msgid ""
"Reinforced deepslate is a very hard block undestructable by even wither "
"explosions. It is unobtainable in survival mode."
msgstr ""
"Arbel sakon indartua bloke oso gogorra da, eta wither leherketekin ere ezin "
"da suntsitu. Ezinezkoa da bizirauteko moduan lortzea."

#: mods/ITEMS/mcl_deepslate/deepslate.lua:51
msgid "Deepslate Coal Ore"
msgstr "Arbel sakoneko ikatz-minerala"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:52
msgid "Deepslate Iron Ore"
msgstr "Arbel sakoneko burdin minerala"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:53
msgid "Deepslate Gold Ore"
msgstr "Arbel sakoneko urre-minerala"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:54
msgid "Deepslate Emerald Ore"
msgstr "Arbel sakoneko esmeralda minerala"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:55
msgid "Deepslate Diamond Ore"
msgstr "Arbel sakoneko diamantezko minerala"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:56
msgid "Deepslate Lapis Lazuli Ore"
msgstr "Arbel sakoneko Lapis Lazuli-minerala"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:57
msgid "Deepslate Redstone Ore"
msgstr "Arbel sakoneko redstone minerala"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:62
msgid "Lit Deepslate Redstone Ore"
msgstr "Argitutako arbel sakoneko redstone minerala"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:69
msgid "Deepslate Copper Ore"
msgstr "Arbel sakoneko kobrezko minerala"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:73
msgid "Cobbled Deepslate"
msgstr "Arbel sakon arrokatsua"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:74
msgid ""
"Cobbled deepslate is a stone variant that functions similar to cobblestone "
"or blackstone."
msgstr ""
"Arbel sakon harritsua harrizko aldaera bat da, eta galtzada-harriaren edo "
"harri beltzaren antzera funtzionatzen du."

#: mods/ITEMS/mcl_deepslate/deepslate.lua:80
msgid "Cobbled Deepslate Stairs"
msgstr "Arbel sakon arrokatsuko eskailerak"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:84
msgid "Cobbled Deepslate Slab"
msgstr "Arbel sakoneko lauza arrokatsua"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:88
msgid "Cobbled Deepslate Wall"
msgstr "Arbel sakoneko horma arrokatsua"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:95
msgid "Polished Deepslate"
msgstr "Arbel sakon leundua"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:96
msgid "Polished deepslate is the stone-like polished version of deepslate."
msgstr "Deepslate leundua harri itxurako deepslatearen bertsio leundua da."

#: mods/ITEMS/mcl_deepslate/deepslate.lua:102
msgid "Polished Deepslate Stairs"
msgstr "Arbel sakon leunduko eskailerak"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:106
msgid "Polished Deepslate Slab"
msgstr "Arbel sakoneko lauza leundua"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:110
msgid "Polished Deepslate Wall"
msgstr "Arbel sakoneko horma leundua"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:117
msgid "Deepslate Bricks"
msgstr "Arbel sakoneko adreiluak"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:118
msgid "Deepslate bricks are the brick version of deepslate."
msgstr "Deepslate adreiluak deepslatearen adreiluzko bertsioa dira."

#: mods/ITEMS/mcl_deepslate/deepslate.lua:125
msgid "Deepslate Brick Stairs"
msgstr "Arbel sakoneko adreiluzko eskailerak"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:129
msgid "Deepslate Brick Slab"
msgstr "Arbel sakoneko adreiluzko lauza"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:133
msgid "Deepslate Brick Wall"
msgstr "Arbel sakoneko adreiluzko horma"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:137
msgid "Cracked Deepslate Bricks"
msgstr "Pitzatutako arbel sakoneko adreiluak"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:143
msgid "Deepslate Tiles"
msgstr "Arbel sakoneko baldosak"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:144
#: mods/ITEMS/mcl_deepslate/deepslate.lua:169
msgid "Deepslate tiles are a decorative variant of deepslate."
msgstr "Arbel sakoneko baldosak arbel sakonaren aldaera apaingarri bat dira."

#: mods/ITEMS/mcl_deepslate/deepslate.lua:150
msgid "Deepslate Tile Stairs"
msgstr "Arbel sakoneko baldosen eskailerak"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:154
msgid "Deepslate Tile Slab"
msgstr "Arbel sakoneko baldosazko lauza"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:158
msgid "Deepslate Tiles Wall"
msgstr "Arbel sakoneko baldosen horma"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:162
msgid "Cracked Deepslate Tiles"
msgstr "Arbel sakoneko baldosa pitzatuak"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:168
msgid "Chiseled Deepslate"
msgstr "Arbel sakon zizelatua"

#: mods/ITEMS/mcl_deepslate/init.lua:13
msgid "@1 is a variant of @2 that can generate in deepslate and tuff blobs."
msgstr ""
"@1 @2-en aldaera bat da, arbel sakoneko eta tobako orbanetan sor daitekeena."

#: mods/ITEMS/mcl_deepslate/init.lua:52
msgid "@1 are a cracked variant."
msgstr "@1 pitzatutako aldaera bat da."

#: mods/ITEMS/mcl_deepslate/tuff.lua:14
msgid "Chiseled Tuff"
msgstr "Toba zizelatua"

#: mods/ITEMS/mcl_deepslate/tuff.lua:15
msgid "Chiseled tuff is a chiseled variant of tuff."
msgstr "Toba zizelatua tobaren aldaera zizelatua da."

#: mods/ITEMS/mcl_deepslate/tuff.lua:26
msgid "Chiseled Tuff Bricks"
msgstr "Toba zizelatuzko adreiluak"

#: mods/ITEMS/mcl_deepslate/tuff.lua:27
msgid ""
"Chiseled tuff bricks are a variant of tuff bricks, featuring a large brick "
"in the center of the block, with geometric design above and below."
msgstr ""
"Toba zizelatuzko adreiluak tobazko adreiluen aldaera bat dira. Blokearen "
"erdian adreilu handi bat dago, eta diseinu geometrikoa du gora eta behera."

#: mods/ITEMS/mcl_deepslate/tuff.lua:39
msgid "Tuff"
msgstr "Toba"

#: mods/ITEMS/mcl_deepslate/tuff.lua:40
msgid ""
"Tuff is an ornamental rock formed from volcanic ash, occurring in "
"underground blobs below Y=16."
msgstr ""
"Toba, errauts bolkanikotik abiatuta sortutako harri apaingarria da, lur "
"azpiko orbanetan dagoena."

#: mods/ITEMS/mcl_deepslate/tuff.lua:47
msgid "Tuff Stairs"
msgstr "Toba eskailerak"

#: mods/ITEMS/mcl_deepslate/tuff.lua:51
msgid "Tuff Slab"
msgstr "Toba-lauza"

#: mods/ITEMS/mcl_deepslate/tuff.lua:55
msgid "Tuff Wall"
msgstr "Toba-horma"

#: mods/ITEMS/mcl_deepslate/tuff.lua:62
msgid "Polished Tuff"
msgstr "Leundutako toba"

#: mods/ITEMS/mcl_deepslate/tuff.lua:63
msgid "Polished tuff is a polished variant of the tuff block."
msgstr "Leundutako toba, toba blokearen leundutako aldaera bat da."

#: mods/ITEMS/mcl_deepslate/tuff.lua:68
msgid "Polished Tuff Stairs"
msgstr "Toba leunduko eskailerak"

#: mods/ITEMS/mcl_deepslate/tuff.lua:72
msgid "Polished Tuff Slab"
msgstr "Leundutako toba lauza"

#: mods/ITEMS/mcl_deepslate/tuff.lua:76
msgid "Polished Tuff Wall"
msgstr "Toba leunduzko horma"

#: mods/ITEMS/mcl_deepslate/tuff.lua:83
msgid "Tuff Bricks"
msgstr "Toba adreiluak"

#: mods/ITEMS/mcl_deepslate/tuff.lua:84
msgid "Tuff bricks are a brick variant of tuff."
msgstr "Tobazko adreiluak tobaren adreilu-aldaera bat dira."

#: mods/ITEMS/mcl_deepslate/tuff.lua:89
msgid "Tuff Bricks Stairs"
msgstr "Toba adreiluzko eskailerak"

#: mods/ITEMS/mcl_deepslate/tuff.lua:93
msgid "Tuff Bricks Slab"
msgstr "Toba adreiluzko lauza"

#: mods/ITEMS/mcl_deepslate/tuff.lua:97
msgid "Tuff Bricks Wall"
msgstr "Toba adreiluzko horma"
