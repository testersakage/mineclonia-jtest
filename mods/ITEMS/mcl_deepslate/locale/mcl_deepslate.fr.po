#: mods/ITEMS/mcl_deepslate/deepslate.lua:73
msgid "Cobbled Deepslate"
msgstr "Pierres des abîmes"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:74
msgid ""
"Cobbled deepslate is a stone variant that functions similar to cobblestone "
"or blackstone."
msgstr ""
"La pierre des abîmes est une variante de roche similaire à la pierre ou la "
"pierre noire."

#: mods/ITEMS/mcl_deepslate/deepslate.lua:80
msgid "Cobbled Deepslate Stairs"
msgstr "Escalier en pierres des abîmes"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:84
