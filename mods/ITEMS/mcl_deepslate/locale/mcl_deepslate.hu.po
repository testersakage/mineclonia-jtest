#: mods/ITEMS/mcl_deepslate/deepslate.lua:95
msgid "Polished Deepslate"
msgstr "Polírozott Mélypala"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:96
msgid "Polished deepslate is the stone-like polished version of deepslate."
msgstr "A polírozott mélypala a mélypala kőszerű, polírozott változata."

