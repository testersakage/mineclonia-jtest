msgstr "Потрескавшиеся сланцевые кирпичи"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:143
msgid "Deepslate Tiles"
msgstr "Сланцевая плитка"

#: mods/ITEMS/mcl_deepslate/deepslate.lua:144
#: mods/ITEMS/mcl_deepslate/deepslate.lua:169
msgid "Deepslate tiles are a decorative variant of deepslate."
msgstr "Сланцевая плитка — это декоративный вариант глубинного сланца."

#: mods/ITEMS/mcl_deepslate/deepslate.lua:150
msgid "Deepslate Tile Stairs"
msgstr "Ступени из сланцевой плитки"

