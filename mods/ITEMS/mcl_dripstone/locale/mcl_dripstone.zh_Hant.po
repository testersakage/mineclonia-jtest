#: mods/ITEMS/mcl_dripstone/init.lua:47
msgid "Dripstone block"
msgstr "滴石方塊"

#: mods/ITEMS/mcl_dripstone/init.lua:48
msgid ""
"Dripstone is type of stone that allows stalagmites and stalagtites to grow "
"on it"
msgstr "滴石是一種石，可以長出石荀和鐘乳石。"

#: mods/ITEMS/mcl_dripstone/init.lua:209
msgid "Pointed dripstone"
msgstr "滴石尖"

#: mods/ITEMS/mcl_dripstone/init.lua:210 mods/ITEMS/mcl_dripstone/init.lua:232
#: mods/ITEMS/mcl_dripstone/init.lua:257
msgid "Pointed dripstone is what stalagmites and stalagtites are made of"
msgstr "滴石尖是石荀和鐘乳石的元件。"

#: mods/ITEMS/mcl_dripstone/init.lua:231 mods/ITEMS/mcl_dripstone/init.lua:256
msgid "Pointed dripstone (@1/@2)"
msgstr "滴石尖（@1/@2）"
