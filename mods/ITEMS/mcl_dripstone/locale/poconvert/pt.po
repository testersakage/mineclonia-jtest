msgid "Dripstone block"
msgstr "Bloco de Espeleotema"

msgid "Dripstone is type of stone that allows stalagmites and stalagtites to grow on it"
msgstr ""
"Espeleotema é um tipo de rocha que permite que estalactites e estalagmites "
"cresçam na mesma"

msgid "Pointed dripstone"
msgstr "Estalactite pontiaguda"

msgid "Pointed dripstone is what stalagmites and stalagtites are made of"
msgstr ""
"Estalactites pontiagudas são o que as estalactites e estalagmites são feitas "
"de"

msgid "Pointed dripstone (@1/@2)"
msgstr "Estalactite pontiaguda (@1/@2)"
