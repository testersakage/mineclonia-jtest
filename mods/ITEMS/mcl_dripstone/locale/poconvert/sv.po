msgid "Dripstone block"
msgstr "Droppstensblock"

msgid "Dripstone is type of stone that allows stalagmites and stalagtites to grow on it"
msgstr ""
"Droppsten är en typ av sten som tillåter stalagmiter och stalaktiter att "
"växa på den"

msgid "Pointed dripstone"
msgstr "Spetsig droppsten"

msgid "Pointed dripstone is what stalagmites and stalagtites are made of"
msgstr "Spetsig droppsten är vad stalagmiter och stalaktiter är gjorda av"

msgid "Pointed dripstone (@1/@2)"
msgstr "Spetsig droppsten (@1/@2)"
