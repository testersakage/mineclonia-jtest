#: mods/ITEMS/mcl_dyes/init.lua:167
msgid "This item is a dye which is used for dyeing and crafting."
msgstr "Questo oggetto è un colorante utilizzato per tingere ed assemblare."

#: mods/ITEMS/mcl_dyes/init.lua:168
msgid ""
"Rightclick on a sheep to dye its wool. Other things are dyed by crafting."
msgstr ""
"Clicca col tasto destro su una pecora per tingerne la lana. Degli altri "
"materiali sono tinti attraverso l'assemblaggio."

