#: mods/ITEMS/mcl_enchanting/enchantments.lua:15
msgid "Bane of Arthropods"
msgstr "Perdición de los Artrópodos"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:21
msgid ""
"Increases damage and applies Slowness IV to arthropod mobs (spiders, cave "
"spiders, silverfish and endermites)."
msgstr ""
"Incrementa el daño y ralentiza a los artrópodos. (arañas, lepismas, "
"endermitas, etc)."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:30
msgid "Channeling"
msgstr "Conductividad"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:34
msgid ""
"Channels a bolt of lightning toward a target. Works only during "
"thunderstorms and if target is unobstructed with opaque blocks."
msgstr "Canaliza los rayos de una tormenta hacia el enemigo."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:43
msgid "Curse of Vanishing"
msgstr "Maldición de desaparición"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:46
msgid "Item destroyed on death."
msgstr "El ítem se destruye tras tu muerte."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:58
msgid "Depth Strider"
msgstr "Agilidad acuática"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:64
msgid "Increases underwater movement speed."
msgstr "Incrementa la velocidad de nado bajo el agua."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:110
msgid "Efficiency"
msgstr "Eficiencia"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:115
msgid "Increases mining speed."
msgstr "Incrementa la velocidad de minado."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:128
msgid "Fire Aspect"
msgstr "Aspecto ígneo"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:132
msgid "Sets target on fire."
msgstr "Incencia al enemigo."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:150
msgid "Flame"
msgstr "Fuego"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:153
msgid "Arrows set target on fire."
msgstr "Las flechas prenderan los enemigos."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:162
msgid "Fortune"
msgstr "Fortuna"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:167
msgid "Increases certain block drops."
msgstr "Incrementa la cantidad de ítems que sueltan los bloques."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:176
msgid "Frost Walker"
msgstr "Paso helado"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:182
msgid ""
"Turns water beneath the player into frosted ice and prevents the damage from "
"magma blocks."
msgstr "Congela el agua bajo tus pies y evita el daño de los bloques de magma."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:209
msgid "Impaling"
msgstr "Empalamiento"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:213
msgid "Trident deals additional damage to ocean mobs."
msgstr "Incrementa el daño del tridente sobre criaturas acuáticas."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:222
msgid "Infinity"
msgstr "Infinidad"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:226
msgid "Shooting consumes no regular arrows."
msgstr "No se consumiran las flechas lanzadas."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:235
msgid "Knockback"
msgstr "Empuje"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:239
msgid "Increases knockback."
msgstr "Incrementa el empuje."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:253
msgid "Looting"
msgstr "Botín"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:257
msgid "Increases mob loot."
msgstr "Incrementa el botín de los enemigos."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:265
msgid "Loyalty"
msgstr "Lealtad"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:270
msgid "Trident returns after being thrown. Higher levels reduce return time."
msgstr "El tridente regresa al portador tras lanzarlo."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:279
msgid "Luck of the Sea"
msgstr "Suerte marina"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:283
msgid "Increases rate of good loot (enchanting books, etc.)"
msgstr "Incrementa la probabilidad de encontrar tesoros"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:292
msgid "Lure"
msgstr "Atracción"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:296
msgid "Decreases time until rod catches something."
msgstr "Disminuye el tiempo que tardan en picar los cebos en la pesca."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:305
msgid "Mending"
msgstr "Reparación"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:309
msgid "Repair the item while gaining XP orbs."
msgstr "Repara los ítems portados al recibir orbes de experiencia."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:371
msgid "Multishot"
msgstr "Multidisparo"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:375
msgid "Shoot 3 arrows at the cost of one."
msgstr "Dispara 3 flechas al precio de una."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:383
msgid "Piercing"
msgstr "Perforación"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:388
msgid "Arrows passes through multiple objects."
msgstr "Las flechas atraviesan multiples objetos."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:397
msgid "Power"
msgstr "Poder"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:401
msgid "Increases arrow damage."
msgstr "Incrementa el daño de las flechas."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:410
msgid "Punch"
msgstr "Retroceso"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:414
msgid "Increases arrow knockback."
msgstr "Incrementa el empuje de las flechas."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:422
msgid "Quick Charge"
msgstr "Carga rápida"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:426
msgid "Decreases crossbow charging time."
msgstr "Disminuye el tiempo de carga de las ballestas."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:435
msgid "Respiration"
msgstr "Respiración"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:440
msgid "Extends underwater breathing time."
msgstr "Aumenta el tiempo de mantener la respiración."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:448
msgid "Riptide"
msgstr "Propulsión acuática"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:453
msgid ""
"Trident launches player with itself when thrown. Works only in water or rain."
msgstr "El tridente impulsa al portador dentro del agua o bajo la lluvia."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:462
msgid "Sharpness"
msgstr "Filo"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:468
msgid "Increases damage."
msgstr "Incrementa el daño."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:478
msgid "Silk Touch"
msgstr "Toque de seda"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:483
msgid "Mined blocks drop themselves."
msgstr "Los bloques se minarán enteros."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:492
msgid "Smite"
msgstr "Golpeo"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:498
msgid "Increases damage to undead mobs."
msgstr "Incrementa el daño contra no-muertos."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:508
msgid "Soul Speed"
msgstr "Velocidad del alma"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:514
msgid "Increases walking speed on soul sand."
msgstr "Incrementa la velocidad al caminar sobre arena de Almas."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:538
msgid "Unbreaking"
msgstr "Irrompibilidad"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:544
msgid "Increases item durability."
msgstr "Incrementa la durabilidad de una herramienta."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:568
msgid "Density"
msgstr "Densidad"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:574
msgid "Increases mace damage when falling."
msgstr "Aumenta el daño del mazo al caer."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:584
msgid "Breach"
msgstr "Fisura"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:590
msgid "Reduces target's armor effectiveness."
msgstr "Reduce la efectividad de la armadura del objetivo."

#: mods/ITEMS/mcl_enchanting/enchantments.lua:600
msgid "Wind Burst"
msgstr "Aeroimpulso"

#: mods/ITEMS/mcl_enchanting/enchantments.lua:605
msgid "Emits a burst of wind from a mace smash attack."
msgstr "Emite una ráfaga de viento por un ataque aplastante del mazo."

#: mods/ITEMS/mcl_enchanting/engine.lua:85
#: mods/ITEMS/mcl_enchanting/engine.lua:93
msgid "Unknown Enchantment"
msgstr "Encantamiento desconocido"

#: mods/ITEMS/mcl_enchanting/engine.lua:604
msgid "Inventory"
msgstr "Inventario"

#: mods/ITEMS/mcl_enchanting/engine.lua:633
msgid "@1 Enchantment Levels"
msgstr "Nivel de encantamiento: @1"

#: mods/ITEMS/mcl_enchanting/engine.lua:635
msgid "Level requirement: @1"
msgstr "Nivel requerido: @1"

#: mods/ITEMS/mcl_enchanting/engine.lua:654
msgid "@1 Lapis Lazuli"
msgstr "@1 Lapislázuli"

#: mods/ITEMS/mcl_enchanting/init.lua:66
msgid "Enchant an item"
msgstr "Encantar ítem"

#: mods/ITEMS/mcl_enchanting/init.lua:67 mods/ITEMS/mcl_enchanting/init.lua:109
msgid "<player> <enchantment> [<level>]"
msgstr "<jugador> <encantamiento> [<nivel>]"

#: mods/ITEMS/mcl_enchanting/init.lua:76
msgid "Usage: /enchant <player> <enchantment> [<level>]"
msgstr "Usa: /enchant <jugador> <encantamiento> [<nivel>]"

#: mods/ITEMS/mcl_enchanting/init.lua:80 mods/ITEMS/mcl_enchanting/init.lua:122
msgid "Player '@1' cannot be found."
msgstr "Jugador @1 no encontrado."

#: mods/ITEMS/mcl_enchanting/init.lua:86 mods/ITEMS/mcl_enchanting/init.lua:127
msgid "There is no such enchantment '@1'."
msgstr "'@1' no es un encantamiento."

#: mods/ITEMS/mcl_enchanting/init.lua:88 mods/ITEMS/mcl_enchanting/init.lua:129
msgid "The target doesn't hold an item."
msgstr "El objetivo no sujeta un ítem."

#: mods/ITEMS/mcl_enchanting/init.lua:90
msgid "The selected enchantment can't be added to the target item."
msgstr "El encantamiento seleccionado no puede añadirse a ese ítem."

#: mods/ITEMS/mcl_enchanting/init.lua:92
msgid "'@1' is not a valid number"
msgstr "'@1' no es un número válido"

#: mods/ITEMS/mcl_enchanting/init.lua:94
msgid "The number you have entered (@1) is too big, it must be at most @2."
msgstr ""
"El número que has introducido (@1) es muy grande, debe ser menor que @2."

#: mods/ITEMS/mcl_enchanting/init.lua:96
msgid "The number you have entered (@1) is too small, it must be at least @2."
msgstr ""
"El número que has introducido (@1) es muy pequeño, debe ser mayor a @2."

#: mods/ITEMS/mcl_enchanting/init.lua:98
msgid "@1 can't be combined with @2."
msgstr "@1 no se puede combinar con @2."

#: mods/ITEMS/mcl_enchanting/init.lua:102
#: mods/ITEMS/mcl_enchanting/init.lua:136
msgid "Enchanting succeded."
msgstr "Encantado correctamente."

#: mods/ITEMS/mcl_enchanting/init.lua:108
msgid "Forcefully enchant an item"
msgstr "Encantar ítem a la fuerza"

#: mods/ITEMS/mcl_enchanting/init.lua:118
msgid "Usage: /forceenchant <player> <enchantment> [<level>]"
msgstr "Usa /forceenchant <jugador> <encantamiento> [<nivel>]"

#: mods/ITEMS/mcl_enchanting/init.lua:131
msgid "The target item is not enchantable."
msgstr "El ítem del jugador no se puede encantar."

#: mods/ITEMS/mcl_enchanting/init.lua:133
msgid "'@1' is not a valid number."
msgstr "'@1' no es un número válido."

#: mods/ITEMS/mcl_enchanting/init.lua:142
msgid "Enchanted Book"
msgstr "Libro encantado"

#: mods/ITEMS/mcl_enchanting/init.lua:232
msgid "Enchanting Table"
msgstr "Mesa de encantamientos"

#: mods/ITEMS/mcl_enchanting/init.lua:233
msgid "Spend experience, and lapis to enchant various items."
msgstr "Gasta experiencia y lapislázuli para encantar varios ítems."

#: mods/ITEMS/mcl_enchanting/init.lua:234
msgid ""
"Enchanting Tables will let you enchant armors, tools, weapons, and books "
"with various abilities. But, at the cost of some experience, and lapis "
"lazuli."
msgstr ""
"La mesa de Encantamientos dara a tus herramientas, armas o armadura algunas "
"habilidades magicas. Pero a coste de algo de experiencia y lapislázuli."

#: mods/ITEMS/mcl_enchanting/init.lua:236
msgid "Rightclick the Enchanting Table to open the enchanting menu."
msgstr "Clic derecho sobre la mesa de encantamientos para abrir la interfaz."

#: mods/ITEMS/mcl_enchanting/init.lua:237
msgid ""
"Place a tool, armor, weapon or book into the top left slot, and then place "
"1-3 Lapis Lazuli in the slot to the right."
msgstr ""
"Coloca una herramienta, arma, armadura o libro sobre la ranura izquierda, "
"coloca de 1 a 3 Lapis lázulis en la ranura derecha."

#: mods/ITEMS/mcl_enchanting/init.lua:238
msgid ""
"After placing your items in the slots, the enchanting options will be shown. "
"Hover over the options to read what is available to you."
msgstr ""
"Coloca el ítem en su ranura y se mostraran los encantamientos a elegir."

#: mods/ITEMS/mcl_enchanting/init.lua:239
msgid ""
"These options are randomized, and dependent on experience level; but the "
"enchantment strength can be increased."
msgstr ""
"Las opciones seran aleatorias dependiendo del nivel de experiencia, los "
"niveles de encantamiento pueden ser aumentados."

#: mods/ITEMS/mcl_enchanting/init.lua:240
msgid ""
"To increase the enchantment strength, place bookshelves around the "
"enchanting table. However, you will need to keep 1 air node between the "
"table, & the bookshelves to empower the enchanting table."
msgstr ""
"Para aumentar los niveles de encantamientos, coloca librerias alrededor y "
"cerca de la mesa de encantamientos."

#: mods/ITEMS/mcl_enchanting/init.lua:241
msgid ""
"After finally selecting your enchantment; left-click on the selection, and "
"you will see both the lapis lazuli and your experience levels consumed. And, "
"an enchanted item left in its place."
msgstr ""
"Despues elige tu encantamiento, los niveles de experiencia y el lapislázuli "
"seran consumidos y el encantamiento aplicado al ítem."

#: mods/ITEMS/mcl_enchanting/init.lua:258
msgid "Enchant"
msgstr "Encantamiento"

#~ msgid "Sweeping Edge"
#~ msgstr "Barrido"

#~ msgid "Increases sweeping attack damage."
#~ msgstr "Incrementa el daño de efecto area."
