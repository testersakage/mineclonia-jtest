msgid "Bane of Arthropods"
msgstr "節肢剋星"

msgid "Increases damage and applies Slowness IV to arthropod mobs (spiders, cave spiders, silverfish and endermites)."
msgstr "增加對節肢生物（蜘蛛、洞穴蜘蛛、蠹魚和終界蟎）的傷害，並造成 緩速IV 效果。"

msgid "Channeling"
msgstr "喚雷"

msgid "Channels a bolt of lightning toward a target. Works only during thunderstorms and if target is unobstructed with opaque blocks."
msgstr "召喚一道閃電擊中目標。僅在暴風雨期間及目標未被不透明方塊阻擋時有效。"

msgid "Curse of Vanishing"
msgstr "消失詛咒"

msgid "Item destroyed on death."
msgstr "使物品在死亡後消失。"

msgid "Depth Strider"
msgstr "深海漫遊"

msgid "Increases underwater movement speed."
msgstr "增加水下移動速度。"

msgid "Efficiency"
msgstr "效率"

msgid "Increases mining speed."
msgstr "提高挖掘效率。"

msgid "Fire Aspect"
msgstr "燃燒"

msgid "Sets target on fire."
msgstr "使目標著火。"

msgid "Flame"
msgstr "火焰"

msgid "Arrows set target on fire."
msgstr "使射出的箭著火。"

msgid "Fortune"
msgstr "幸運"

msgid "Increases certain block drops."
msgstr "增加特定方塊的掉落物數量。"

msgid "Frost Walker"
msgstr "冰霜行者"

msgid "Turns water beneath the player into frosted ice and prevents the damage from magma blocks."
msgstr "將玩家腳下的水變成霜冰，並消除岩漿塊造成的傷害。"

msgid "Impaling"
msgstr "魚叉"

msgid "Trident deals additional damage to ocean mobs."
msgstr "使三叉戟對水生生物造成額外傷害。"

msgid "Infinity"
msgstr "無限"

msgid "Shooting consumes no regular arrows."
msgstr "射擊不消耗普通箭矢。"

msgid "Knockback"
msgstr "擊退"

msgid "Increases knockback."
msgstr "增加擊退距離。"

msgid "Looting"
msgstr "掠奪"

msgid "Increases mob loot."
msgstr "增加被殺死生物的掉落物數量。"

