#: mods/ITEMS/mcl_flowerpots/init.lua:57 mods/ITEMS/mcl_flowerpots/init.lua:99
#: mods/ITEMS/mcl_flowerpots/init.lua:146
msgid "Flower Pot"
msgstr "Maceta"

#: mods/ITEMS/mcl_flowerpots/init.lua:58
msgid "Can hold a small flower or plant"
msgstr "Puede contener una pequeña flor o planta"

#: mods/ITEMS/mcl_flowerpots/init.lua:59
msgid ""
"Flower pots are decorative blocks in which flowers and other small plants "
"can be placed."
msgstr ""
"Las macetas son bloques decorativos en los que se pueden colocar flores y "
"otras plantas pequeñas."

#: mods/ITEMS/mcl_flowerpots/init.lua:60
msgid ""
"Just place a plant on the flower pot. Flower pots can hold small flowers "
"(not higher than 1 block), saplings, ferns, dead bushes, mushrooms and "
"cacti. Rightclick a potted plant to retrieve the plant."
msgstr ""
"Simplemente coloque una planta en la maceta. Las macetas pueden contener "
"flores pequeñas (no más de 1 bloque), árboles jóvenes, helechos, arbustos "
"muertos, hongos y cactus. Haga clic derecho en una planta en maceta para "
"recuperar la planta."
