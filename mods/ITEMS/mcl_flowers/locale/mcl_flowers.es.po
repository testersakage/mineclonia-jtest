#: mods/ITEMS/mcl_flowers/init.lua:8
msgid ""
"This is a small flower. Small flowers are mainly used for dye production and "
"can also be potted."
msgstr ""
"Esta es una pequeña flor. Las flores pequeñas se utilizan principalmente "
"para la producción de tinte y también se pueden macetas."

#: mods/ITEMS/mcl_flowers/init.lua:9
msgid "It can only be placed on a block on which it would also survive."
msgstr "Solo se puede colocar en un bloque en el que también sobreviviría."

#: mods/ITEMS/mcl_flowers/init.lua:383
msgid "@1 (Top Part)"
msgstr "@1 (Parte superior)"

