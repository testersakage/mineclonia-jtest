#: mods/ITEMS/mcl_flowers/init.lua:8
msgid ""
"This is a small flower. Small flowers are mainly used for dye production and "
"can also be potted."
msgstr ""
"Isso é uma flor pequena. Flores pequenas são majoritariamente usadas para a "
"produção de corantes e também podem ser envasadas."

#: mods/ITEMS/mcl_flowers/init.lua:9
msgid "It can only be placed on a block on which it would also survive."
msgstr "Apenas pode ser posicionada em um bloco ao qual vai sobreviver."

#: mods/ITEMS/mcl_flowers/init.lua:383
msgid "@1 (Top Part)"
msgstr "@1 (Topo)"

