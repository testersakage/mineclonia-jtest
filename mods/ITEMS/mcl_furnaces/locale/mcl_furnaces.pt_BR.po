#: mods/ITEMS/mcl_furnaces/init.lua:32 mods/ITEMS/mcl_furnaces/init.lua:71
msgid "Inventory"
msgstr "Inventário"

#: mods/ITEMS/mcl_furnaces/init.lua:40 mods/ITEMS/mcl_furnaces/init.lua:79
msgid "Recipe book"
msgstr "Livro de receitas"

#: mods/ITEMS/mcl_furnaces/init.lua:424 mods/ITEMS/mcl_furnaces/init.lua:585
#: mods/ITEMS/mcl_furnaces/init.lua:615 mods/ITEMS/mcl_furnaces/init.lua:664
msgid "Furnace"
msgstr "Fornalha"

#: mods/ITEMS/mcl_furnaces/init.lua:616
msgid "Uses fuel to smelt or cook items"
msgstr "Usa combustível para derreter ou cozinhar itens"

#: mods/ITEMS/mcl_furnaces/init.lua:617
msgid ""
"Furnaces cook or smelt several items, using a furnace fuel, into something "
"else."
msgstr ""
"Fornalhas cozinham ou fundem vários itens, usando um combustível de "
"fornalha, para transformá-los em outra coisa."

#: mods/ITEMS/mcl_furnaces/init.lua:619
msgid "Use the furnace to open the furnace menu."
msgstr "Use a fornalha para abrir o menu da fornalha."

#: mods/ITEMS/mcl_furnaces/init.lua:620
msgid ""
"Place a furnace fuel in the lower slot and the source material in the upper "
"slot."
msgstr ""
"Posicione um combustível de fornalha no slot mais baixo e o material fonte "
"no slot acima."

#: mods/ITEMS/mcl_furnaces/init.lua:621
msgid "The furnace will slowly use its fuel to smelt the item."
msgstr "A fornalha irá usar lentamente seu combustível para derreter o item."

#: mods/ITEMS/mcl_furnaces/init.lua:622
msgid "The result will be placed into the output slot at the right side."
msgstr "O resultado será posicionado no slot de saída no lado direito."

#: mods/ITEMS/mcl_furnaces/init.lua:623
msgid ""
"Use the recipe book to see what you can smelt, what you can use as fuel and "
"how long it will burn."
msgstr ""
"Use o livro de receitas para ver o que você pode derreter, o que você pode "
"usar como combustível e por quanto tempo irá queimar."

#: mods/ITEMS/mcl_furnaces/init.lua:631
msgid "Burning Furnace"
msgstr "Fornalha Queimando"
