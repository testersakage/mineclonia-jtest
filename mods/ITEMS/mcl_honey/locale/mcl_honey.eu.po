#: mods/ITEMS/mcl_honey/init.lua:23
msgid "Honeycomb"
msgstr "Beraska"

#: mods/ITEMS/mcl_honey/init.lua:24
msgid ""
"Used to craft beehives and protect copper blocks from further oxidation."
msgstr ""
"Hegaztien apiarioak egiteko eta kobrezko blokeak babesteko erabiltzen da."

#: mods/ITEMS/mcl_honey/init.lua:25
msgid "Use on copper blocks to prevent further oxidation."
msgstr "Kobrezko blokeen gainean erabiltzen du, oxidazio handiagoa saihesteko."

#: mods/ITEMS/mcl_honey/init.lua:32
msgid "Honeycomb Block"
msgstr "Beraska blokea"

#: mods/ITEMS/mcl_honey/init.lua:33
msgid "Honeycomb Block. Used as a decoration."
msgstr "Abaraska blokea. Dekorazio gisa erabiltzen da."

#: mods/ITEMS/mcl_honey/init.lua:44
msgid "Honey Bottle"
msgstr "Ezti-botila"

#: mods/ITEMS/mcl_honey/init.lua:45
msgid ""
"Honey Bottle is used to craft honey blocks and to restore hunger points."
msgstr ""
"Ezti-botilak ezti-blokeak egiteko eta gose-puntuak lehengoratzeko balio du."

#: mods/ITEMS/mcl_honey/init.lua:46
msgid ""
"Drinking will restore 6 hunger points. Can also be used to craft honey "
"blocks."
msgstr ""
"Edateak 6 gose-puntu berreskuratuko ditu. Ezti blokeak egiteko ere erabil "
"daiteke."

#: mods/ITEMS/mcl_honey/init.lua:72
msgid "Honey Block"
msgstr "Ezti-blokea"

#: mods/ITEMS/mcl_honey/init.lua:73
msgid ""
"Honey Block. Used as a decoration and in redstone. Is sticky on some sides."
msgstr ""
"Ezti-blokea. Dekorazio eta redstone gisa erabiltzen da. Alde batzuetatik "
"itsaskorra da."
