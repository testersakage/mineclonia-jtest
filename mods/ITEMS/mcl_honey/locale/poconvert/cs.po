msgid "Honeycomb"
msgstr "Voština"

msgid "Used to craft beehives and protect copper blocks from further oxidation."
msgstr "Používá se k výrobě úlů a k ochraně měděných bloků před další oxidací."

msgid "Use on copper blocks to prevent further oxidation."
msgstr "Použijte na měděné bloky, abyste zabránili další oxidaci."

msgid "Honeycomb Block"
msgstr "Voštinový blok"

msgid "Honeycomb Block. Used as a decoration."
msgstr "Voštinový blok. Používá se jako dekorace."

msgid "Honey Bottle"
msgstr "Lahev medu"

msgid "Honey Bottle is used to craft honey blocks and to restore hunger points."
msgstr "Láhev medu se používá k výrobě medových bloků a k zahnání hladu."

msgid "Drinking will restore 6 hunger points. Can also be used to craft honey blocks."
msgstr "Vypití obnoví 6 bodů hladu. Lze také použít k výrobě medových bloků."

msgid "Honey Block"
msgstr ""

msgid "Honey Block. Used as a decoration and in redstone. Is sticky on some sides."
msgstr ""
