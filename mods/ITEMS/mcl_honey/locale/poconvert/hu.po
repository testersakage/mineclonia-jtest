msgid "Honeycomb"
msgstr "Mézescsiga"

msgid "Used to craft beehives and protect copper blocks from further oxidation."
msgstr ""
"A kaptár készítésére és a rézblokkok további oxidációjától való védelmére "
"használható."

msgid "Use on copper blocks to prevent further oxidation."
msgstr "Használd rézblokkokon a további oxidáció megakadályozására."

msgid "Honeycomb Block"
msgstr "Mézescsiga blokk"

msgid "Honeycomb Block. Used as a decoration."
msgstr "Mézescsiga blokk. Dekorációként használható."

msgid "Honey Bottle"
msgstr "Mézes üveg"

msgid "Honey Bottle is used to craft honey blocks and to restore hunger points."
msgstr ""
"A mézes üveg mézblokkok készítésére és az éhségpontok visszaállítására "
"használható."

msgid "Drinking will restore 6 hunger points. Can also be used to craft honey blocks."
msgstr ""
"Fogyasztása 6 éhségpontot állít vissza. Mézblokkok készítésére is "
"használható."

msgid "Honey Block"
msgstr "Mézblokk"

msgid "Honey Block. Used as a decoration and in redstone. Is sticky on some sides."
msgstr ""
"Mézblokk. Dekorációként és redstone-ban használható. Néhány oldalán ragadós."
