#: mods/ITEMS/mcl_itemframes/register.lua:5
msgid "Item Frame"
msgstr "Moldura"

#: mods/ITEMS/mcl_itemframes/register.lua:6
msgid "Can hold an item"
msgstr "Pode conter um item"

#: mods/ITEMS/mcl_itemframes/register.lua:7
#: mods/ITEMS/mcl_itemframes/register.lua:19
msgid "Item frames are decorative blocks in which items can be placed."
msgstr "Molduras são blocos decorativos em que itens podem ser colocados."

#: mods/ITEMS/mcl_itemframes/register.lua:8
#: mods/ITEMS/mcl_itemframes/register.lua:20
msgid ""
"Just place any item on the item frame. Use the item frame again to retrieve "
"the item."
msgstr ""
"Basta colocar qualquer item na moldura. Use a moldura de novo para pegar o "
"item de volta."

#: mods/ITEMS/mcl_itemframes/register.lua:17
msgid "Glow Item Frame"
msgstr "Moldura Brilhante"

#: mods/ITEMS/mcl_itemframes/register.lua:18
msgid "Can hold an item and glows"
msgstr "Pode conter um item e brilha"

#: mods/ITEMS/mcl_itemframes/register.lua:30
msgid "Invisible Item Frame"
msgstr "Moldura Invisível"

#: mods/ITEMS/mcl_itemframes/register.lua:32
msgid "Can hold an item but is invisible"
msgstr "Pode conter um item, mas é invisível"

#: mods/ITEMS/mcl_itemframes/register.lua:41
msgid "Invisible Glow Item Frame"
msgstr "Moldura Invisível com Brilho"

#: mods/ITEMS/mcl_itemframes/register.lua:43
msgid "Can hold an item and glows but is invisible"
msgstr "Pode conter um item e é invisível, mas brilha"

#: mods/ITEMS/mcl_itemframes/register.lua:52
msgid "Glow and Behold!"
msgstr "Brilhe e Contemple!"

#: mods/ITEMS/mcl_itemframes/register.lua:53
msgid "Craft a glow item frame."
msgstr "Produza uma moldura brilhante."
