msgid "Item Frame"
msgstr "Marco"

msgid "Can hold an item"
msgstr "Puedes colocar un objeto"

msgid "Item frames are decorative blocks in which items can be placed."
msgstr ""
"Los marcos son bloques decorativos en los que se pueden colocar objetos."

msgid "Just place any item on the item frame. Use the item frame again to retrieve the item."
msgstr ""
"Simplemente coloque cualquier objeto en el marco. Haz clic en el marco "
"nuevamente para recuperar el objeto."

msgid "Glow Item Frame"
msgstr "Marco brillante"

msgid "Can hold an item and glows"
msgstr "Puede colocar un objeto y brilla"

msgid "Glow and Behold!"
msgstr "¡Brillante idea!"

msgid "Craft a glow item frame."
msgstr "Fabrica un marco brillante."
