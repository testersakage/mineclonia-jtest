msgid "Item Frame"
msgstr "아이템 액자"

msgid "Can hold an item"
msgstr "아이템 전시 가능"

msgid "Item frames are decorative blocks in which items can be placed."
msgstr "아이템 액자는 아이템을 걸어둘 수 있는 장식용 블록입니다."

msgid "Just place any item on the item frame. Use the item frame again to retrieve the item."
msgstr ""
"원하는 아이템을 들고 액자에 사용해 보세요. 액자를 다시 사용하면 아이템을 "
"꺼낼 수 있습니다."

msgid "Glow Item Frame"
msgstr "발광 아이템 액자"

msgid "Can hold an item and glows"
msgstr "아이템 전시 가능 및 밝게 빛남"

msgid "Invisible Item Frame"
msgstr "투명 아이템 액자"

msgid "Can hold an item but is invisible"
msgstr "아이템 전시 시 투명해짐"

msgid "Invisible Glow Item Frame"
msgstr "투명한 발광 아이템 액자"

msgid "Can hold an item and glows but is invisible"
msgstr "아이템 전시 시 투명해짐 및 밝게 빛남"

msgid "Glow and Behold!"
msgstr "밝은 말 고운 말!"

msgid "Craft a glow item frame."
msgstr "발광 아이템 액자를 제작하세요."
