msgid "Item Frame"
msgstr "Рамка"

msgid "Can hold an item"
msgstr "Может удерживать предмет"

msgid "Item frames are decorative blocks in which items can be placed."
msgstr "Рамки — это декоративные блоки, в которые можно помещать предметы."

msgid "Just place any item on the item frame. Use the item frame again to retrieve the item."
msgstr "Просто поместите в рамку любой предмет. Используйте рамку вновь, чтобы забрать из неё предмет обратно."

msgid "Glow Item Frame"
msgstr "Светящаяся рамка"

msgid "Can hold an item and glows"
msgstr "Может удерживать предмет и светится"

msgid "Glow and Behold!"
msgstr "Сияй и созерцай!"

msgid "Craft a glow item frame."
msgstr "Создайте светящуюся рамку."
