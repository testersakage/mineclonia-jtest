msgid "Lantern"
msgstr "燈籠"

#: mods/ITEMS/mcl_lanterns/register.lua:5
#: mods/ITEMS/mcl_lanterns/register.lua:13
msgid ""
"Lanterns are light sources which can be placed on the top or the bottom of "
"most blocks."
msgstr "燈籠是一種發光方塊，可以放置在大多數方塊的上方或下方。"

#: mods/ITEMS/mcl_lanterns/register.lua:12
msgid "Soul Lantern"
msgstr "靈魂燈籠"

#: mods/ITEMS/mcl_lanterns/register.lua:41
msgid "Chain"
msgstr "鎖鏈"

#: mods/ITEMS/mcl_lanterns/register.lua:42
msgid "Chains are metallic decoration blocks."
msgstr "鎖鏈 是一種金屬裝飾性方塊。"
