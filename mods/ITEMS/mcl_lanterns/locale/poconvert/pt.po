msgid "Chain"
msgstr "Corrente"

msgid "Chains are metallic decoration blocks."
msgstr "Correntes são blocos de decoração metálicos."

msgid "Lantern"
msgstr "Lanterna"

msgid "Lanterns are light sources which can be placed on the top or the bottom of most blocks."
msgstr ""
"Lanternas são fontes de luz que podem ser colocadas em cima ou baixo dos "
"blocos."

msgid "Soul Lantern"
msgstr "Lanterna das Almas"
