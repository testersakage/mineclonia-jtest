#: mods/ITEMS/mcl_lush_caves/dripleaf.lua:113
#: mods/ITEMS/mcl_lush_caves/dripleaf.lua:114
#: mods/ITEMS/mcl_lush_caves/dripleaf.lua:115
#: mods/ITEMS/mcl_lush_caves/dripleaf.lua:116
msgid "Small Dripleaf"
msgstr "Kis csepplevél"

#: mods/ITEMS/mcl_lush_caves/dripleaf.lua:203
#: mods/ITEMS/mcl_lush_caves/dripleaf.lua:204
#: mods/ITEMS/mcl_lush_caves/dripleaf.lua:205
#: mods/ITEMS/mcl_lush_caves/dripleaf.lua:206
msgid "Big Dripleaf"
msgstr "Nagy csepplevél"

#: mods/ITEMS/mcl_lush_caves/init.lua:223
msgid "Azalea Plant"
msgstr "Azálea növény"

#: mods/ITEMS/mcl_lush_caves/init.lua:229
msgid "Flowering Azalea Plant"
msgstr "Virágzó azálea növény"

#: mods/ITEMS/mcl_lush_caves/nodes.lua:78
#: mods/ITEMS/mcl_lush_caves/nodes.lua:80
msgid "Moss"
msgstr "Moha"

#: mods/ITEMS/mcl_lush_caves/nodes.lua:79
msgid "Moss is a green block found in lush caves"
msgstr "A moha zöld blokk, amely buja barlangokban található"

#: mods/ITEMS/mcl_lush_caves/nodes.lua:90
msgid "Moss Carpet"
msgstr "Mohaszőnyeg"

#: mods/ITEMS/mcl_lush_caves/nodes.lua:91
msgid "A moss carpet is a flat variant of the moss block."
msgstr "A mohaszőnyeg a moha blokk lapos változata."

#: mods/ITEMS/mcl_lush_caves/nodes.lua:115
#: mods/ITEMS/mcl_lush_caves/nodes.lua:116
#: mods/ITEMS/mcl_lush_caves/nodes.lua:117
msgid "Hanging roots"
msgstr "Lógó gyökerek"

#: mods/ITEMS/mcl_lush_caves/nodes.lua:118
msgid ""
"Hanging roots are a decorative block found hanging from rooted dirt in lush "
"caves."
msgstr ""
"A lógó gyökerek dekoratív blokkok, amelyek a gyökeres földből lógnak buja "
"barlangokban."

#: mods/ITEMS/mcl_lush_caves/nodes.lua:152
#: mods/ITEMS/mcl_lush_caves/nodes.lua:153
#: mods/ITEMS/mcl_lush_caves/nodes.lua:154
msgid "Cave vines"
msgstr "Barlangi indák"

#: mods/ITEMS/mcl_lush_caves/nodes.lua:155
msgid ""
"Cave vines are decorative blocks growing from the ceiling of lush caves."
msgstr ""
"A barlangi indák dekoratív blokkok, amelyek a buja barlangok mennyezetéről "
"nőnek."

#: mods/ITEMS/mcl_lush_caves/nodes.lua:201
#: mods/ITEMS/mcl_lush_caves/nodes.lua:202
#: mods/ITEMS/mcl_lush_caves/nodes.lua:203
msgid "Lit Cave vines"
msgstr "Világító barlangi indák"

#: mods/ITEMS/mcl_lush_caves/nodes.lua:204
msgid ""
"Lit cave vines are light emitting decorative blocks growing from the ceiling "
"of lush caves."
msgstr ""
"A világító barlangi indák fényt kibocsátó dekoratív blokkok, amelyek a buja "
"barlangok mennyezetéről nőnek."

#: mods/ITEMS/mcl_lush_caves/nodes.lua:237
msgid "Rooted dirt"
msgstr "Gyökeres föld"

#: mods/ITEMS/mcl_lush_caves/nodes.lua:238
msgid "Rooted dirt is type of dirt found in lush caves."
msgstr "A gyökeres föld a buja barlangokban található talajtípus."

#: mods/ITEMS/mcl_lush_caves/nodes.lua:270
msgid "Glow berry"
msgstr "Fénybogyó"

#: mods/ITEMS/mcl_lush_caves/nodes.lua:271
msgid "This is a food item which can be eaten."
msgstr "Ez egy ehető táplálék."

#: mods/ITEMS/mcl_lush_caves/nodes.lua:351
msgid "Azalea Leaves"
msgstr "Azálea levelek"

#: mods/ITEMS/mcl_lush_caves/nodes.lua:352
msgid "Leaves of an Azalea tree"
msgstr "Egy azálea fa levelei"

#: mods/ITEMS/mcl_lush_caves/nodes.lua:361
msgid "Flowering Azalea Leaves"
msgstr "Virágzó azálea levelek"

#: mods/ITEMS/mcl_lush_caves/nodes.lua:362
msgid "The Flowering Leaves of an Azalea tree"
msgstr "Egy azálea fa virágzó levelei"

#: mods/ITEMS/mcl_lush_caves/nodes.lua:372
msgid "Spore blossom"
msgstr "Spóravirág"

#: mods/ITEMS/mcl_lush_caves/nodes.lua:373
msgid "Spore blossoms are a type of flower found in lush caves."
msgstr "A spóravirágok a buja barlangokban található virágok egy típusa."

#: mods/ITEMS/mcl_lush_caves/nodes.lua:411
msgid "Needs soil and bone meal to grow"
msgstr "Növekedéshez talajt és csontport igényel"

#: mods/ITEMS/mcl_lush_caves/nodes.lua:457
msgid "Azalea"
msgstr "Azálea"

#: mods/ITEMS/mcl_lush_caves/nodes.lua:458
msgid ""
"Azalea is a small plant which often occurs in lush caves. It can be broken "
"by hand or any tool. By using bone meal, azalea can be turned into an azalea "
"tree."
msgstr ""
"Azálea egy kis növény, amely gyakran előfordul buja barlangokban. Kézzel "
"vagy bármely eszközzel törhető. Csontpor használatával az azálea "
"átalakítható azálea fává."

#: mods/ITEMS/mcl_lush_caves/nodes.lua:472
#: mods/ITEMS/mcl_lush_caves/nodes.lua:474
msgid "Flowering Azalea"
msgstr "Virágzó azálea"

#: mods/ITEMS/mcl_lush_caves/nodes.lua:473
msgid ""
"Flowering azalea is a small plant which often occurs in lush caves. It can "
"be broken by hand or any tool. By using bone meal, flowering azalea can be "
"turned into an azalea tree."
msgstr ""
"A virágzó azálea egy kis növény, amely gyakran előfordul buja barlangokban. "
"Kézzel vagy bármely eszközzel törhető. Csontpor használatával a virágzó "
"azálea átalakítható azálea fává."
