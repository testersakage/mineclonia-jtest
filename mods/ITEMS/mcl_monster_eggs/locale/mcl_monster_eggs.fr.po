#: mods/ITEMS/mcl_monster_eggs/init.lua:14
msgid "Hides a silverfish"
msgstr "Cache un poisson d'argent"

#: mods/ITEMS/mcl_monster_eggs/init.lua:15
#, fuzzy
msgid ""
"\t\t\tAn infested block is a block from which a silverfish will pop out when "
"it is broken.\n"
"\t\t\tIt looks identical to its normal counterpart.\n"
"\t\t"
msgstr ""
"\n"
"\t\t\tUn bloc infesté est un bloc d'où sort un poisson d'argent lorsqu'il "
"est cassé.\n"
"\t\t\tIl est identique à son homologue normal.\n"
"\t\t"

