#: mods/ITEMS/mcl_mud/init.lua:4
msgid "Mud"
msgstr "Barro"

#: mods/ITEMS/mcl_mud/init.lua:5
msgid ""
"Mud is a decorative block that generates in mangrove swamps. Mud can also be "
"obtained by using water bottles on dirt or coarse dirt."
msgstr ""
"Barro é um bloco decorativo que gera em manguezais. Barro também pode ser "
"obtido por usar garrafas de água em terra ou terra infértil."

#: mods/ITEMS/mcl_mud/init.lua:24
msgid "Packed Mud"
msgstr "Barro Seco"

#: mods/ITEMS/mcl_mud/init.lua:25
msgid "Packed mud is a decorative block used to craft mud bricks."
msgstr "Barro seco é um bloco decorativo usado para craftar tijolos de barro."

#: mods/ITEMS/mcl_mud/init.lua:37
msgid "Mud Bricks"
msgstr "Tijolos de Barro"

#: mods/ITEMS/mcl_mud/init.lua:38
msgid "Decorative block crafted from packed mud."
msgstr "Bloco decorativo craftado com barro seco."

#: mods/ITEMS/mcl_mud/init.lua:50
msgid "Mud Brick Stair"
msgstr "Escadas de Tijolos de Barro Seco"

#: mods/ITEMS/mcl_mud/init.lua:51
msgid "Mud Brick Slab"
msgstr "Degrau de Tijolos de Barro Seco"
