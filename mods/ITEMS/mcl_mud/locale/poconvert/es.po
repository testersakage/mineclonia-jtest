msgid "Mud"
msgstr "Barro"

msgid "Mud is a decorative block that generates in mangrove swamps. Mud can also be obtained by using water bottles on dirt or coarse dirt."
msgstr ""
"El barro es un bloque decorativo que se genera en los manglares. El barro "
"también se puede obtener utilizando botellas de agua sobre tierra o tierra "
"infértil."

msgid "Packed Mud"
msgstr "Adobe"

msgid "Packed mud is a decorative block used to craft mud bricks."
msgstr ""
"El adobe es un bloque decorativo que se utiliza para fabricar ladrillos de "
"adobe."

msgid "Mud Bricks"
msgstr "Ladrillos de adobe"

msgid "Decorative block crafted from packed mud."
msgstr "Bloque decorativo elaborado con adobe."

msgid "Mud Brick Stair"
msgstr "Escalera de ladrillos de adobe"

msgid "Mud Brick Slab"
msgstr "Losa de ladrillos de adobe"
