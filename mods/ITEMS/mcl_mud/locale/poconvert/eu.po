msgid "Mud"
msgstr "Lokatza"

msgid "Mud is a decorative block that generates in mangrove swamps. Mud can also be obtained by using water bottles on dirt or coarse dirt."
msgstr ""
"Lokatza mangletan sortzen den dekorazio-bloke bat da. Lokatza ere lor "
"daiteke ur botilak erabiliz lur gainean edo lur esterila."

msgid "Packed Mud"
msgstr "Adobe"

msgid "Packed mud is a decorative block used to craft mud bricks."
msgstr ""
"Adobea adobezko adreiluak egiteko erabiltzen den dekorazio-bloke bat da."

msgid "Mud Bricks"
msgstr "Adobezko adreiluak"

msgid "Decorative block crafted from packed mud."
msgstr "Adobez fabrikatutako dekorazio-blokea."

msgid "Mud Brick Stair"
msgstr "Adobezko adreiluzko eskailera"

msgid "Mud Brick Slab"
msgstr "Adobezko adreiluzko lauza"
