msgstr "Тёмный призмарин"

#: mods/ITEMS/mcl_ocean/prismarine.lua:67
msgid "Prismarine Stairs"
msgstr "Призмариновые ступени"

#: mods/ITEMS/mcl_ocean/prismarine.lua:68
msgid "Prismarine Slab"
msgstr "Призмариновая плита"

#: mods/ITEMS/mcl_ocean/prismarine.lua:73
msgid "Prismarine Brick Stairs"
msgstr "Ступени из призмаринового кирпича"

#: mods/ITEMS/mcl_ocean/prismarine.lua:74
msgid "Prismarine Brick Slab"
msgstr "Плита из призмаринового кирпича"

#: mods/ITEMS/mcl_ocean/prismarine.lua:79
msgid "Dark Prismarine Stairs"
msgstr "Ступени из тёмного призмарина"

#: mods/ITEMS/mcl_ocean/prismarine.lua:80
