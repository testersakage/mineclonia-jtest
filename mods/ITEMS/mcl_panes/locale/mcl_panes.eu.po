#: mods/ITEMS/mcl_panes/init.lua:209
msgid ""
"Glass panes are thin layers of glass which neatly connect to their neighbors "
"as you build them."
msgstr ""
"Kristalezko panelak kristalezko geruza meheak dira, eta eraikitzen dituen "
"heinean, ezin hobeto konektatzen dira beste kristal batzuekin."

#: mods/ITEMS/mcl_panes/init.lua:214
msgid ""
"Stained glass panes are thin layers of stained glass which neatly connect to "
"their neighbors as you build them. They come in many different colors."
msgstr ""
"Kristalezko panelak kristalezko geruza meheak dira, eta eraikitzen dituen "
"heinean, ezin hobeto konektatzen dira beste kristal batzuekin. Kolore "
"askotan etortzen dira."

#: mods/ITEMS/mcl_panes/init.lua:215
msgid "Stained Glass Pane"
msgstr "Zikindutako kristal tindatuzko panela"

#: mods/ITEMS/mcl_panes/init.lua:247
msgid "Iron Bars"
msgstr "Burdinazko barroteak"

#: mods/ITEMS/mcl_panes/init.lua:248
msgid "Iron bars neatly connect to their neighbors as you build them."
msgstr ""
"Burdinazko barroteak ezin hobeto lotzen zaizkie bizilagunei eraiki ahala."

#: mods/ITEMS/mcl_panes/init.lua:262
msgid "Glass Pane"
msgstr "Kristalezko panela"

