#: mods/ITEMS/mcl_potions/splash.lua:14
msgid ""
"A throwable potion that will shatter on impact, where it gives all nearby "
"players and mobs a status effect or a set of status effects."
msgstr ""
"Une potion jetable qui explose à l'impact, où elle donne à tous les joueurs "
"et mobs un effet de statut ou plusieurs effets de statuts."

#: mods/ITEMS/mcl_potions/tipped_arrow.lua:25
msgid ""
"This particular arrow is tipped and will give an effect when it hits a "
"player or mob."
msgstr ""
"Cette flèche particulière est enchantée et donnera un effet lorsqu'elle "
"touche un joueur ou un mob."
