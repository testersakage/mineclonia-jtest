#: mods/ITEMS/mcl_potions/potions.lua:326
msgid "Dragon's Breath"
msgstr "ドラゴンブレス"

#: mods/ITEMS/mcl_potions/potions.lua:327
msgid ""
"This item is used in brewing and can be combined with splash potions to "
"create lingering potions."
msgstr ""
"醸造に使用するアイテムで、飛散ポーションと組み合わせて滞留ポーションが作れま"
"す。"

#: mods/ITEMS/mcl_potions/potions.lua:336
msgid "Has an awkward taste and is used for brewing potions."
msgstr "味に癖があり、ポーションの醸造に使用されます。"

#: mods/ITEMS/mcl_potions/potions.lua:344
msgid "Has a terrible taste and is not really useful for brewing potions."
msgstr ""

#: mods/ITEMS/mcl_potions/potions.lua:352
msgid "Has a bitter taste and is not really useful for brewing potions."
msgstr ""

#: mods/ITEMS/mcl_potions/potions.lua:360
msgid "+@1 HP"
msgstr "+@1 HP"

#: mods/ITEMS/mcl_potions/potions.lua:362
msgid "Instantly heals."
msgstr "即座に治癒します。"

#: mods/ITEMS/mcl_potions/potions.lua:375
msgid "-@1 HP"
msgstr "-@1 HP"

#: mods/ITEMS/mcl_potions/potions.lua:377
msgid "Instantly deals damage."
msgstr "即座にダメージを与えます。"

#: mods/ITEMS/mcl_potions/potions.lua:390
msgid "Increases the perceived brightness of light under a dark sky."
msgstr "暗い空の下で、光の明るさを感じやすくします。"

#: mods/ITEMS/mcl_potions/potions.lua:402
msgid "Increases walking speed."
msgstr "歩行速度が上がります。"

#: mods/ITEMS/mcl_potions/potions.lua:414
msgid "Decreases walking speed."
msgstr "歩行速度が下がります。"

#: mods/ITEMS/mcl_potions/potions.lua:430
msgid "Increases jump strength."
msgstr "ジャンプ力を高めます。"

#: mods/ITEMS/mcl_potions/potions.lua:442
msgid ""
"Applies the withering effect which deals damage at a regular interval and "
"can kill."
msgstr ""

#: mods/ITEMS/mcl_potions/potions.lua:454
msgid "Applies the poison effect which deals damage at a regular interval."
msgstr "一定間隔でダメージを与える毒効果を及ぼします。"

#: mods/ITEMS/mcl_potions/potions.lua:466
msgid "Regenerates health over time."
msgstr "時間経過でヘルスを回復します。"

#: mods/ITEMS/mcl_potions/potions.lua:478
msgid "Grants invisibility."
msgstr "不可視性を付与します。"

#: mods/ITEMS/mcl_potions/potions.lua:490
msgid "Grants limitless breath underwater."
msgstr "水中で無限の呼吸を付与します。"

#: mods/ITEMS/mcl_potions/potions.lua:502
msgid "Grants immunity to damage from heat sources like fire."
msgstr "火などの熱源から受けるダメージに対する免疫力を付与します。"

#: mods/ITEMS/mcl_potions/potions.lua:514
msgid "Increases attack power."
msgstr "攻撃の威力が上昇する。"

#: mods/ITEMS/mcl_potions/potions.lua:526
msgid "Decreases attack power."
msgstr "攻撃の威力が低下する。"

#: mods/ITEMS/mcl_potions/potions.lua:538
msgid "Instead of falling, you descend gracefully."
msgstr "落下速度を低下させ。"

#: mods/ITEMS/mcl_potions/potions.lua:550
msgid "Decreases damage taken at the cost of speed."
msgstr ""

#: mods/ITEMS/mcl_potions/potions.lua:570
msgid "Increases luck."
msgstr ""

#: mods/ITEMS/mcl_potions/potions.lua:582
msgid "Decreases luck."
msgstr ""

#: mods/ITEMS/mcl_potions/potions.lua:597
msgid "Attracts danger."
msgstr ""

#: mods/ITEMS/mcl_potions/potions.lua:611
msgid ""
"Causes 1-3 silverfish to spawn with a 5% chance when damaged. It not applies "
"to silverfishes."
msgstr ""

#: mods/ITEMS/mcl_potions/potions.lua:621
msgid "Causes 2 medium slimes to spawn on death. It not applies to slimes."
msgstr ""

#: mods/ITEMS/mcl_potions/potions.lua:631
msgid ""
"Causes 2-3 cobwebs to appear on death. Also increases walking speed when "
"crossing cobwebs."
msgstr ""

#: mods/ITEMS/mcl_potions/potions.lua:641
msgid "Causes A wind burst on death."
msgstr ""

