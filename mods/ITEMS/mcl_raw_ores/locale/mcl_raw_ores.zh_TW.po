#: mods/ITEMS/mcl_raw_ores/init.lua:33
msgid "Raw Iron"
msgstr "鐵原礦"

#: mods/ITEMS/mcl_raw_ores/init.lua:33
msgid "Block of Raw Iron"
msgstr "鐵原礦方塊"

#: mods/ITEMS/mcl_raw_ores/init.lua:33
msgid "Raw Iron. Mine an Iron ore to get it."
msgstr "鐵原礦。開採鐵礦可以獲得。"

#: mods/ITEMS/mcl_raw_ores/init.lua:34
msgid ""
"A block of raw Iron is mostly a decorative block but also useful as a "
"compact storage of raw Iron."
msgstr "鐵原礦方塊可以用作裝飾，也可以壓縮儲存鐵原礦。"

#: mods/ITEMS/mcl_raw_ores/init.lua:35
msgid "Raw Gold"
msgstr "金原礦"

#: mods/ITEMS/mcl_raw_ores/init.lua:35
msgid "Block of Raw Gold"
msgstr "金原礦方塊"

#: mods/ITEMS/mcl_raw_ores/init.lua:35
msgid "Raw Gold. Mine a Gold ore to get it."
msgstr "金原礦。開採金礦可以獲得。"

#: mods/ITEMS/mcl_raw_ores/init.lua:36
msgid ""
"A block of raw Gold is mostly a decorative block but also useful as a "
"compact storage of raw Gold."
msgstr "金原礦方塊可以用作裝飾，也可以壓縮儲存金原礦。"
