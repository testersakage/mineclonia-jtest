msgid "Brush"
msgstr "Brotxa"

msgid "Brushes are used in archeology to discover hidden items"
msgstr "Brotxak arkeologian erabiltzen dira ezkutuko itemak aurkitzeko"

msgid "Use the brush on a suspicious node to uncover its secrets"
msgstr "Erabili brotxa nodo susmagarri batean bere sekretuak ezagutzeko"

msgid "Suspicious Sand"
msgstr "Harea Susmagarria"

msgid "Suspicious Gravel"
msgstr "Legar Susmagarria"
