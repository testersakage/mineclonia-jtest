#: mods/ITEMS/mcl_vaults/api.lua:75 mods/ITEMS/mcl_vaults/api.lua:76
msgid ""
"A vault ejects loot when opened with the right key. It can only be opened "
"once by each player."
msgstr ""
"Kutxa gotor batek altxorra ematen du giltza egokiarekin irekitzen denean. "
"Jokalari bakoitzeko behin bakarrik ireki dezake."

