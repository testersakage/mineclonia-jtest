msgid "Vault"
msgstr "Cofre"

msgid "Ejects loot when opened with the key"
msgstr "Ejeta espólio quando aberto com a chave"

msgid "A vault ejects loot when opened with the right key. It can only be opened once by each player."
msgstr ""
"Um cofre ejeta espólio quando aberto com a chave certa. Pode ser aberto uma "
"só vez por jogador."

msgid "Trial Key"
msgstr "Chave de Desafio"

msgid "Ominous Trial Key"
msgstr "Chave de Desafio Sombria"

msgid "Ominous Vault"
msgstr "Cofre Sombrio"
