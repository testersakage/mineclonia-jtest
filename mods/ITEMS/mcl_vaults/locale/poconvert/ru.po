msgid "Vault"
msgstr "Хранилище"

msgid "Ejects loot when opened with the key"
msgstr "Выбрасывает лут при открытии ключом"

msgid "A vault ejects loot when opened with the right key. It can only be opened once by each player."
msgstr ""
"Хранилище выбрасывает лут при открытии правильным ключом. Оно может быть "
"открыто каждым игроком только раз."

msgid "Trial Key"
msgstr "Ключ испытаний"

msgid "Ominous Trial Key"
msgstr "Зловещий ключ испытаний"

msgid "Ominous Vault"
msgstr "Зловещее хранилище"
