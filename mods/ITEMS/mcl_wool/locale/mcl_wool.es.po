#: mods/ITEMS/mcl_wool/init.lua:25
msgid "Carpet"
msgstr "Alfombra"

#: mods/ITEMS/mcl_wool/init.lua:26
msgid "Wool"
msgstr "Lana"

#: mods/ITEMS/mcl_wool/init.lua:27
msgid "Wool is a decorative block which comes in many different colors."
msgstr ""
"La lana es un bloque decorativo que viene en muchos colores diferentes."

#: mods/ITEMS/mcl_wool/init.lua:28
msgid "Carpets are thin floor covers which come in many different colors."
msgstr ""
"Las alfombras son finas cubiertas para el suelo que vienen en muchos colores "
"diferentes."

