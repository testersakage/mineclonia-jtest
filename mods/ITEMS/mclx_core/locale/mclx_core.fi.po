#: mods/ITEMS/mclx_core/init.lua:5
msgid "River Water Source"
msgstr "Jokivesilähde"

#: mods/ITEMS/mclx_core/init.lua:13
msgid ""
"River water has the same properties as water, but has a reduced flowing "
"distance and is not renewable."
msgstr ""
"Jokivedellä on samat ominaisuudet kuin vedellä, mutta se ei virtaa yhtä "
"pitkälle eikä se ole uusiutuva."

#: mods/ITEMS/mclx_core/init.lua:14
msgid "River Water"
msgstr "Jokivesi"

#: mods/ITEMS/mclx_core/init.lua:31
msgid "Flowing River Water"
msgstr "Virtaava jokivesi"
