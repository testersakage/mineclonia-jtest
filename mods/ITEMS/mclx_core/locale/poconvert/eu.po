msgid "River Water Source"
msgstr "Ibaiko Ur-iturria"

msgid "River water has the same properties as water, but has a reduced flowing distance and is not renewable."
msgstr ""
"Ibaiko urak uraren propietate berak ditu, baina fluxu-distantzia txikia du "
"eta ez da berriztagarria."

msgid "River Water"
msgstr "Ibaiko Ura"

msgid "Flowing River Water"
msgstr "Jarioan dabilen Ibaiko Ura"
