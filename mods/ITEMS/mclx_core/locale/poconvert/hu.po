msgid "River Water Source"
msgstr "Folyóvízgóc"

msgid "River water has the same properties as water, but has a reduced flowing distance and is not renewable."
msgstr ""
"A folyóvíz tulajdonságai ugyanolyanok, mint a víznek, csak nem folyik olyan "
"messzire, és nem képződik újra."

msgid "River Water"
msgstr "Folyóvíz"

msgid "Flowing River Water"
msgstr "Folyó folyóvíz"
