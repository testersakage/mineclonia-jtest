msgid "River Water Source"
msgstr "Fonte de Água do Rio"

msgid "River water has the same properties as water, but has a reduced flowing distance and is not renewable."
msgstr ""
"Água do rio tem as mesmas propriedades que a água, mas uma distância de "
"escoamento reduzida e é não renovável."

msgid "River Water"
msgstr "Água do Rio"

msgid "Flowing River Water"
msgstr "Água do Rio Corrente"
