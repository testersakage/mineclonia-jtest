#: mods/MAPGEN/mcl_biome_dispatch/init.lua:791
msgid "Loading terrain"
msgstr "Lur-eremua kargatzen"

#: mods/MAPGEN/mcl_biome_dispatch/init.lua:1103
msgid ""
"Locate a structure, biome, or point of interest identified by ID in the "
"current dimension."
msgstr ""
"Topatu uneko dimentsioan IDz identifikatutako egitura, bioma edo interes-"
"gunea."

#: mods/MAPGEN/mcl_biome_dispatch/init.lua:1109
msgid ""
"/locate structure requires a structure ID.\n"
"These structures are available: "
msgstr ""
"/locate egitura-k egituraren ID bat behar du.\n"
"Egitura hauek daude erabilgarri: "

#: mods/MAPGEN/mcl_biome_dispatch/init.lua:1121
msgid ""
"The nearest structure of type @1 is located at (@2,@3,@4) (@5 block away)"
msgid_plural ""
"The nearest structure of type @1 is located at (@2,@3,@4) (@5 blocks away)"
msgstr[0] ""
msgstr[1] ""

#: mods/MAPGEN/mcl_biome_dispatch/init.lua:1126
msgid "No structure of type @1 exists near your position"
msgstr "Ez dago @1 motako egiturarik existitzen zuren inguruan"

#: mods/MAPGEN/mcl_biome_dispatch/init.lua:1135
msgid ""
"/locate biome requires a biome ID or a tag prefixed with `#'.\n"
"These biomes and tags are available: "
msgstr ""
"/locate bioma-k bioma ID bat edo '#'-z hasten den etiketa bat behar du.\n"
"Bioma eta etiketa hauek daude erabilgarri: "

#: mods/MAPGEN/mcl_biome_dispatch/init.lua:1147
msgid "The nearest biome matching @1 is located at (@2,@3,@4) (@5 block away)"
msgid_plural ""
"The nearest biome matching @1 is located at (@2,@3,@4) (@5 blocks away)"
msgstr[0] ""
msgstr[1] ""

#: mods/MAPGEN/mcl_biome_dispatch/init.lua:1152
msgid "No biome matching @1 exists near your position"
msgstr "Ez dago @1 motako biomarik zure inguruan"

#: mods/MAPGEN/mcl_biome_dispatch/init.lua:1159
msgid ""
"/locate poi requires an identifier designating a valid point of interest.\n"
"These points of interest are available: "
msgstr ""
"/locate interes-guneak balio duen interes-gune bat markatzen duen "
"identifikadore bat behar du.\n"
"Interes-gune hauek daude erabilgarri: "

#: mods/MAPGEN/mcl_biome_dispatch/init.lua:1168
msgid "@1 does not identify a valid point of interest"
msgstr "Ezin da @1-ekin interes-gunerik identifikdatu"

#: mods/MAPGEN/mcl_biome_dispatch/init.lua:1195
msgid "No point of interest named @1 exists near your position"
msgstr "Ez da @1 izeneko interes-gunerik existitzen zure inguruan"

#: mods/MAPGEN/mcl_biome_dispatch/init.lua:1200
msgid ""
"The nearest point of interest named @1 is located at (@2,@3,@4) (@5 block "
"away)"
msgid_plural ""
"The nearest point of interest named @1 is located at (@2,@3,@4) (@5 blocks "
"away)"
msgstr[0] ""
msgstr[1] ""

#: mods/MAPGEN/mcl_biome_dispatch/init.lua:1207
msgid "Usage: /locate [structure | biome | poi] <ID>"
msgstr "Erabilera: /locate [egitura | bioma | interes-gunea] <ID>"
