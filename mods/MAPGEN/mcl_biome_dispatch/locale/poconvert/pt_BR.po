msgid "Loading terrain"
msgstr "Carregando terreno"

msgid "Locate a structure, biome, or point of interest identified by ID in the current dimension."
msgstr ""
"Localize uma estrutura, bioma ou ponto de interesse identificado por ID na "
"dimensão atual."

msgid "No structure of type @1 exists near your position"
msgstr "Não existe estrutura do tipo @1 perto da sua posição"

msgid "No biome matching @1 exists near your position"
msgstr "Não existe bioma correspondente a @1 perto da sua posição"

msgid "@1 does not identify a valid point of interest"
msgstr "@1 não identifica um ponto de interesse válido"

msgid "No point of interest named @1 exists near your position"
msgstr "Não existe ponto de interesse válido chamado @1 perto da sua posição"

msgid "Usage: /locate [structure | biome | poi] <ID>"
msgstr "Uso: /locate [structure | biome | poi] <ID>"

msgid "/locate structure requires a structure ID.\n"
"These structures are available: "
msgstr ""
"A estrutura /locate requer uma ID de estrutura.\n"
"As seguintes estruturas estão disponíveis: "

msgid "/locate biome requires a biome ID or a tag prefixed with `#'.\n"
"These biomes and tags are available: "
msgstr ""
"O comando /locate biome requer um ID de bioma ou uma etiqueta com o prefixo "
"`#`.\n"
"Os seguintes biomas e etiquetas estão disponíveis: "

msgid "/locate poi requires an identifier designating a valid point of interest.\n"
"These points of interest are available: "
msgstr ""
"O comando /locate poi requer um identificador que designe um ponto de "
"interesse válido.\n"
"Os seguintes pontos de interesse estão disponíveis: "
