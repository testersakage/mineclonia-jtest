msgid "Loading terrain"
msgstr "Загрузка местности"

msgid "Locate a structure, biome, or point of interest identified by ID in the current dimension."
msgstr ""
"Ищет структуру, биом или точку интереса по идентификатору в текущем "
"измерении."

msgid "No structure of type @1 exists near your position"
msgstr "Рядом с вашей позицией не существует структур типа @1"

msgid "No biome matching @1 exists near your position"
msgstr "Рядом с вашей позицией не существует биома, соответствующего @1"

msgid "@1 does not identify a valid point of interest"
msgstr "@1 не идентифицирует действительную точку интереса"

msgid "No point of interest named @1 exists near your position"
msgstr "Рядом с вашей позицией нет объекта с названием @1"

msgid "Usage: /locate [structure | biome | poi] <ID>"
msgstr "Использование: /locate [structure | biome | poi] <ID>"

msgid "/locate structure requires a structure ID.\n"
"These structures are available: "
msgstr ""
"/locate structure требует идентификатор структуры.\n"
"Доступны следующие структуры: "

msgid "/locate biome requires a biome ID or a tag prefixed with `#'.\n"
"These biomes and tags are available: "
msgstr ""
"/locate biome требует идентификатор биома или тег с префиксом `#'.\n"
"Доступны следующие биомы и теги: "

msgid "/locate poi requires an identifier designating a valid point of interest.\n"
"These points of interest are available: "
msgstr ""
"/locate poi требует идентификатор, обозначающий действительную точку "
"интереса.\n"
"Доступны следующие достопримечательности: "
