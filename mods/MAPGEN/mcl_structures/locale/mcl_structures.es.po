#: mods/MAPGEN/mcl_structures/init.lua:126
msgid "Generate a pre-defined structure near your position."
msgstr "Genere una estructura predefinida cerca de su posición."

#: mods/MAPGEN/mcl_structures/init.lua:138
msgid "Structure placed."
msgstr "Estructura colocada."

#: mods/MAPGEN/mcl_structures/init.lua:142
msgid "Error: No structure type given. Please use “/spawnstruct <type>”."
msgstr ""
"Error: no se especifica ningún tipo de estructura. Utilice \"/spawnstruct "
"<Tipo>\"."

#: mods/MAPGEN/mcl_structures/init.lua:151
msgid "Error: Unknown structure type. Please use “/spawnstruct <type>”."
msgstr ""
"Error: tipo de estructura desconocido. Utilice \"/spawnstruct <Tipo>\"."

#: mods/MAPGEN/mcl_structures/init.lua:156
msgid "Use /help spawnstruct to see a list of available types."
msgstr ""
"Utilice /help spawnstruct para ver una lista de estructuras disponibles."
