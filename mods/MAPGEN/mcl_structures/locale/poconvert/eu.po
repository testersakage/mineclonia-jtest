msgid "Generate a pre-defined structure near your position."
msgstr "Zure posiziotik hurbil aurrez definitutako egitura bat sortzen da."

msgid "Structure placed."
msgstr "Jarritako egitura."

msgid "Error: No structure type given. Please use “/spawnstruct <type>”."
msgstr "Errorea: ez da egiturarik zehaztu. Erabili \"/spawnstruct <mota>\"."

msgid "Error: Unknown structure type. Please use “/spawnstruct <type>”."
msgstr "Errorea: egitura mota ezezaguna. Erabili \"/spawnstruct <mota>\"."

msgid "Use /help spawnstruct to see a list of available types."
msgstr "Erabili /help spawnstruct eskuragarri dauden egitura zerrenda ikusteko."
