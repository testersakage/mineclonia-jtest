msgid "Generate a pre-defined structure near your position."
msgstr "Générez une structure prédéfinie près de votre position."

msgid "Structure placed."
msgstr "Structure placée."

msgid "Error: No structure type given. Please use “/spawnstruct <type>”."
msgstr ""
"Erreur : Aucun type de structure indiqué. Veuillez utiliser \"/spawnstruct "
"<type>\"."

msgid "Error: Unknown structure type. Please use “/spawnstruct <type>”."
msgstr ""
"Erreur : Type de structure inconnu. Veuillez utiliser \"/spawnstruct <type>\""
"."

msgid "Use /help spawnstruct to see a list of available types."
msgstr "Utilisez /help spawnstruct pour voir la liste des types disponibles."
