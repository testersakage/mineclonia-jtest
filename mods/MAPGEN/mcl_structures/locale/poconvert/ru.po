msgid "Generate a pre-defined structure near your position."
msgstr "Генерирует поблизости заранее определённую структуру."

msgid "Structure placed."
msgstr "Структура размещена."

msgid "Error: No structure type given. Please use “/spawnstruct <type>”."
msgstr "Ошибка: Не задан тип структуры. Пожалуйста, используйте “/spawnstruct <тип>”."

msgid "Error: Unknown structure type. Please use “/spawnstruct <type>”."
msgstr "Ошибка: Неизвестный тип структуы. Пожалуйста, используйте “/spawnstruct <тип>”."

msgid "Use /help spawnstruct to see a list of available types."
msgstr ""
"Используйте команду /help spawnstruct, чтобы посмотреть список доступных "
"типов."
