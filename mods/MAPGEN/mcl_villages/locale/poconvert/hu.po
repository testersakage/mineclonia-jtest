msgid "Crop type @1 is not supported"
msgstr "@1 típusú növény nem támogatott"

msgid "The timer for this @1 has not run yet!"
msgstr "Ezen @1 időzítője még nem futott le!"

msgid "Prevent paths from being placed during villager generation. Replaced by air after village path generation"
msgstr ""
"A falu generálása közben megakadályozza, hogy út képződjön a helyén. A falu "
"útjainak generálása után kicserélődik levegővel"

msgid "Mark the node as a good place for paths to connect to"
msgstr "A kockát jó lehetséges kapcsolódási helyként jelöli meg az utak számára"

msgid "A place to plant @1 crops"
msgstr "@1 növények ültetésére szolgáló hely"

msgid "Example POI"
msgstr "Fontos helyre példa"
