#: mods/MISC/mcl_commands/alias.lua:17
msgid "List bans"
msgstr "Liste des interdictions"

#: mods/MISC/mcl_commands/alias.lua:20
msgid "Ban list: @1"
msgstr "Liste d'interdiction : @1"

#: mods/MISC/mcl_commands/kill.lua:5
msgid "Players can't be killed right now, damage has been disabled."
msgstr ""
"Les joueurs ne peuvent pas être tués pour le moment, les dégâts ont été "
"désactivés."

#: mods/MISC/mcl_commands/kill.lua:9
msgid "Player @1 does not exist."
msgstr "Le joueur @1 n'existe pas."

#: mods/MISC/mcl_commands/kill.lua:12
msgid "You are already dead"
msgstr "Tu es déjà mort"

#: mods/MISC/mcl_commands/kill.lua:14
msgid "@1 is already dead"
msgstr "@1 est déjà mort"

#: mods/MISC/mcl_commands/kill.lua:33
msgid "[<name>]"
msgstr "[<nom>]"

#: mods/MISC/mcl_commands/kill.lua:34
msgid "Kill player or yourself"
msgstr "Tuez un joueur ou vous-même"

#: mods/MISC/mcl_commands/list.lua:4
msgid "Show who is logged on"
msgstr "Afficher qui est connecté"

#: mods/MISC/mcl_commands/say.lua:4
msgid "Can use /say"
msgstr "Peut utiliser /say"

#: mods/MISC/mcl_commands/say.lua:8
msgid "<message>"
msgstr "<message>"

#: mods/MISC/mcl_commands/say.lua:9
msgid "Send a message to every player"
msgstr "Envoyez un message à chaque joueur"

#: mods/MISC/mcl_commands/say.lua:13
msgid "Invalid usage, see /help say."
msgstr "Utilisation non valide, voir /help say."

#: mods/MISC/mcl_commands/seed.lua:4
msgid "Displays the world seed"
msgstr "Affiche la graine du monde"

#: mods/MISC/mcl_commands/setblock.lua:4
msgid "<X>,<Y>,<Z> <NodeString>"
msgstr "<X>,<Y>,<Z> <NodeString>"

#: mods/MISC/mcl_commands/setblock.lua:5
msgid "Set node at given position"
msgstr "Placer le noeud à une position donnée"

#: mods/MISC/mcl_commands/setblock.lua:15
msgid "Invalid node"
msgstr "Noeud non valide"

#: mods/MISC/mcl_commands/setblock.lua:18
msgid "@1 spawned."
msgstr "@1 est apparu."

#: mods/MISC/mcl_commands/setblock.lua:20
msgid "Invalid parameters (see /help setblock)"
msgstr "Paramètres invalides (voir /help setblock)"

#: mods/MISC/mcl_commands/sound.lua:4
msgid "<sound> <target>"
msgstr "<sound> <target>"

#: mods/MISC/mcl_commands/sound.lua:5
msgid "Play a sound. Arguments: <sound>: name of the sound. <target>: Target."
msgstr "Jouer un son. Arguments : <sound> : nom du son. <target> : cible."

#: mods/MISC/mcl_commands/sound.lua:18
msgid "Sound name is invalid!"
msgstr "Le nom du son n'est pas valide !"

#: mods/MISC/mcl_commands/sound.lua:23
msgid "Target is invalid!!"
msgstr "La cible n'est pas valide !"

#: mods/MISC/mcl_commands/summon.lua:8
msgid "Only peaceful mobs allowed!"
msgstr "Seuls les mobs pacifiques sont autorisées !"
