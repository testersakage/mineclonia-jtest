msgid "[<gamemode>] [<player>]"
msgstr "[<gamemode>] [<player>]"

msgid "Change gamemode (survival/creative/0/1/s/c) for yourself or player"
msgstr "Změnit herní režim (survival/creative/0/1/s/c) pro sebe nebo zadaného hráče"

msgid "Player not online"
msgstr "Hráč není online"

msgid "Failed to set gamemode @1 for player @2"
msgstr "Nepodařilo se nastavit herní režim @1 pro hráče @2"

msgid "Player @1 is still in creative mode because world is in creative mode"
msgstr ""
"Hráč @1 je stále v kreativním režimu, protože je svět v kreativním režimu"

msgid "Gamemode for player @1: @2"
msgstr "Herní režim pro hráče @1: @2"
