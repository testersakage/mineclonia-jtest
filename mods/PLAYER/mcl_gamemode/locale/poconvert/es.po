msgid "[<gamemode>] [<player>]"
msgstr "[<modo de juego>] [<jugador>]"

msgid "Change gamemode (survival/creative/0/1/s/c) for yourself or player"
msgstr ""
"Cambiar el modo de juego (survival/creative/0/1/s/c) para ti o para un "
"jugador"

msgid "Player not online"
msgstr "Jugador no en línea"

msgid "Failed to set gamemode @1 for player @2"
msgstr "Error al establecer el modo de juego @1 para el jugador @2"

msgid "Player @1 is still in creative mode because world is in creative mode"
msgstr ""
"El jugador @1 sigue en modo creativo porque el mundo está en modo creativo"

msgid "Gamemode for player @1: @2"
msgstr "Modo de juego para el jugador @1: @2"
