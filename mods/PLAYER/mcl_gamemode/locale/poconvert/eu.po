msgid "[<gamemode>] [<player>]"
msgstr "[<joko modua>] [<jokalaria>]"

msgid "Change gamemode (survival/creative/0/1/s/c) for yourself or player"
msgstr ""
"Joko modua aldatzea (bizirautea/sortzailea/0/1/s/c) zuretzat edo jokalari "
"batentzat"

msgid "Player not online"
msgstr "Jokalaria ez-linean"

msgid "Failed to set gamemode @1 for player @2"
msgstr "Errorea @2 jokalariarentzat @1 jokatzeko modua ezartzean"

msgid "Player @1 is still in creative mode because world is in creative mode"
msgstr ""
"@1 jokalariak sortzaile moduan jarraitzen du mundua modu sortzailean "
"dagoelako"

msgid "Gamemode for player @1: @2"
msgstr "@1 Jokalariarentzako joko modua: @2"
