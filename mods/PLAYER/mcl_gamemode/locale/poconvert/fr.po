msgid "[<gamemode>] [<player>]"
msgstr "[<gamemode>] [<player>]"

msgid "Change gamemode (survival/creative/0/1/s/c) for yourself or player"
msgstr ""
"Change le mode de jeu (survie/créatif/0/1/s/c) pour vous-même ou un autre "
"joueur"

msgid "Player not online"
msgstr "Le joueur n'est pas en ligne"

msgid "Failed to set gamemode @1 for player @2"
msgstr "Échec de la configuration du mode de jeu @1 pour le joueur @2"

msgid "Player @1 is still in creative mode because world is in creative mode"
msgstr ""
"Le joueur @1 est toujours en mode créatif parce que le monde est en mode "
"créatif"

msgid "Gamemode for player @1: @2"
msgstr "Mode de jeu pour le joueur @1 : @2"
