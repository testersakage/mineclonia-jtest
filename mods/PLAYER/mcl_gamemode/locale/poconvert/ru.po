msgid "[<gamemode>] [<player>]"
msgstr "[<режим_игры>] [<игрок>]"

msgid "Change gamemode (survival/creative/0/1/s/c) for yourself or player"
msgstr "Изменить режим игры (survival/creative/0/1/s/c) для себя или игрока"

msgid "Player not online"
msgstr "Игрок не в сети"

msgid "Failed to set gamemode @1 for player @2"
msgstr "Не удалось установить режим игры @1 для игрока @2"

msgid "Player @1 is still in creative mode because world is in creative mode"
msgstr ""
"Игрок @1 всё ещё в творческом режиме, так как мир тоже в творческом режиме"

msgid "Gamemode for player @1: @2"
msgstr "Режим игры для игрока @1: @2"
