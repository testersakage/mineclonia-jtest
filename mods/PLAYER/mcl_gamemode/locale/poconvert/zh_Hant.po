msgstr "[<遊戲模式>] [<玩家>]"

msgid "Change gamemode (survival/creative) for yourself or player"
msgstr "設定自己或指定玩家的遊戲模式（生存 survival | 創造 creative）"

msgid "Player not online"
msgstr "玩家不在線"

msgid "Failed to set Gamemode @1 for player @2"
msgstr "失敗：玩家 @2 無法設定為 @1 模式"

msgid "Gamemode for player @1: @2"
msgstr "玩家 @1 的遊戲模為現在為 @2"
