msgid "Respawn position cleared!"
msgstr "Feltámadási hely megszűnt!"

msgid "New respawn position set!"
msgstr "Új feltámadási helyet választottál!"

msgid "Couldn't get level of your respawn anchor!"
msgstr "Nem lehet megállapítani a lélekhorgonyod szintjét!"

msgid "Your spawn bed was missing or blocked, and you had no charged respawn anchor!"
msgstr ""
"A feltámadáshoz használt ágyad eltűnt vagy el van torlaszolva, és nem volt "
"töltött lélekhorgonyod sem!"
